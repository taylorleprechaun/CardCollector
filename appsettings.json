{
  "Auth": {
    "CookieName": "CardCollectorAuth",
    "CookieExpirationHours": 8
  },
  "CardDataSettings": {
    "CacheTtlDays": 7,
    "ImageCacheTtlDays": 30,
    "PricingDelayMs": 100,
    "YamlYugiUrl": "https://dawnbrandbots.github.io/yaml-yugi/cards.yaml"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=Data/collection.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
