@page
@model BrowseModel
@using CardCollector.Data.Models
@using CardCollector.ViewModels
@{
    ViewData["Title"] = "Browse";
    var returnURL = Uri.EscapeDataString(Request.Path + Request.QueryString);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Browse Cards</h1>
    <span class="text-muted">@Model.Results.TotalCount.ToString("N0") cards</span>
</div>

<partial name="_SearchBar" model='new SearchBarViewModel(
    AutocompleteURL: "?handler=Autocomplete",
    FilterCount: Model.ActiveFilterCount,
    PageSize: Model.PageSize,
    Placeholder: "Search by name, set, or rarity…",
    Query: Model.Query)' />

<div class="collapse @(Model.HasActiveFilters ? "show" : "")" id="filterPanel">
    <div class="card card-body mb-3">
        <form method="get">
            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />
            @if (!string.IsNullOrWhiteSpace(Model.Query))
            {
                <input type="hidden" name="query" value="@Model.Query" />
            }
            <partial name="_AdvancedFilters" model='new AdvancedFiltersViewModel
            {
                AvailableRarityNames = Model.AvailableRarityNames,
                AvailableSetNames = Model.AvailableSetNames,
                CurrentCardType = Model.CardType,
                CurrentRarityName = Model.RarityName,
                CurrentSetName = Model.SetName
            }' />
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary btn-sm">Apply Filters</button>
                <a href="/Browse@(!string.IsNullOrWhiteSpace(Model.Query) ? $"?query={Uri.EscapeDataString(Model.Query)}" : "")"
                   class="btn btn-outline-secondary btn-sm">Clear Filters</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Results.Items.Any())
{
    <div class="alert alert-info">
        @if (string.IsNullOrEmpty(Model.Query) && !Model.HasActiveFilters)
        {
            <span>No cards found.</span>
        }
        else
        {
            <span>No cards match your search or filters.</span>
        }
    </div>
}
else
{
    <div class="list-group mb-4">
        @foreach (var item in Model.Results.Items)
        {
            <div class="list-group-item d-flex align-items-center gap-3 py-2">
                <partial name="_CardThumbnail" model='new CardThumbnailViewModel(item.ImageURLSmall, item.Name)' />
                <div class="flex-grow-1 min-width-0">
                    <a href="/Card?id=@item.CardID&returnURL=@returnURL"
                       class="fw-semibold text-decoration-none stretched-link">@item.Name</a>
                    <div class="text-muted small">
                        @item.CardType
                        @if (!string.IsNullOrEmpty(item.Type))
                        {
                            <span>/ @item.Type</span>
                        }
                        @if (!string.IsNullOrEmpty(item.Attribute))
                        {
                            <span> &mdash; @item.Attribute</span>
                        }
                    </div>
                </div>
                @if (item.Status == CollectionStatus.Ordered)
                {
                    <span class="badge bg-primary flex-shrink-0">Ordered</span>
                }
                else if (item.Status == CollectionStatus.Owned)
                {
                    @if (item.CompletionStatus == CollectionCompletionStatus.Complete)
                    {
                        <span class="badge bg-success flex-shrink-0">Complete</span>
                    }
                    else if (item.CompletionStatus == CollectionCompletionStatus.Incomplete)
                    {
                        <span class="badge bg-warning text-dark flex-shrink-0">Incomplete</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary flex-shrink-0">Placeholder</span>
                    }
                }
            </div>
        }
    </div>

    <partial name="_Pagination" model='new PaginationViewModel { AriaLabel = "Card list pagination", PageName = "Browse", PageNumber = Model.PageNumber, PageSize = Model.PageSize, Query = Model.Query, TotalPages = Model.Results.TotalPages, HasPreviousPage = Model.Results.HasPreviousPage, HasNextPage = Model.Results.HasNextPage, AdditionalParams = Model.GetPaginationParams() }' />
}
