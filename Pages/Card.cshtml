@page
@model CardModel
@using CardCollector.Data.Models
@using CardCollector.Extensions
@{
    ViewData["Title"] = Model.CurrentCard?.Name ?? "Card";
    var primaryImage = (Model.ImageID != 0
        ? Model.CurrentCard?.CardImages?.FirstOrDefault(img => img.ID == Model.ImageID)
        : null)
        ?? Model.CurrentCard?.CardImages?.FirstOrDefault();
}

@if (!string.IsNullOrEmpty(Model.ReturnURL))
{
    <a href="@Model.ReturnURL" class="btn btn-outline-secondary btn-sm mb-3">&larr; Back</a>
}

@if (Model.CardNotFound)
{
    <div class="alert alert-warning">Card not found.</div>
}
else if (Model.CurrentCard is not null && primaryImage is not null)
{
    <div class="row g-4">
        <div class="col-md-4 col-lg-3 text-center">
            <img src="@primaryImage.ImageURL"
                 alt="@Model.CurrentCard.Name"
                 class="img-fluid rounded shadow"
                 style="max-width: 280px;" />
        </div>
        <div class="col-md-8 col-lg-9">
            <h2>@Model.CurrentCard.Name</h2>
            <p class="text-muted mb-1">
                @Model.CurrentCard.CardType
                @if (!string.IsNullOrEmpty(Model.CurrentCard.Type))
                {
                    <span>/ @Model.CurrentCard.Type</span>
                }
                @if (!string.IsNullOrEmpty(Model.CurrentCard.Attribute))
                {
                    <span> &mdash; @Model.CurrentCard.Attribute</span>
                }
            </p>
            @if (Model.CurrentCard.ATK.HasValue || Model.CurrentCard.DEF.HasValue)
            {
                <p class="text-muted mb-1">
                    @if (Model.CurrentCard.ATK.HasValue)
                    {
                        <span>ATK&nbsp;@Model.CurrentCard.ATK</span>
                    }
                    @if (Model.CurrentCard.DEF.HasValue)
                    {
                        <span class="ms-3">DEF&nbsp;@Model.CurrentCard.DEF</span>
                    }
                    @if (Model.CurrentCard.Level.HasValue)
                    {
                        <span class="ms-3">Level&nbsp;@Model.CurrentCard.Level</span>
                    }
                </p>
            }
            <p class="mt-2">@Model.CurrentCard.Description</p>

            @if (Model.CurrentCard.CardSets?.Any() == true)
            {
                <h5 class="mt-4">Available Printings</h5>
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="cc-table-head">
                            <tr>
                                <th class="d-none d-md-table-cell">Set</th>
                                <th>Code</th>
                                <th>Rarity</th>
                                <th>Collection</th>
                                <th class="d-none d-md-table-cell">Preferred</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var sortedSets = Model.CurrentCard.CardSets
                                    .OrderBy(s => {
                                        var d = Model.GetTCGDate(s.Code ?? string.Empty);
                                        return string.IsNullOrEmpty(d) ? "9999-99-99" : d;
                                    });
                            }
                            @foreach (var set in sortedSets)
                            {
                                <tr>
                                    <td class="d-none d-md-table-cell">@set.Name</td>
                                    <td><code>@set.Code</code></td>
                                    <td>@set.RarityName</td>
                                    <td>
                                        @{
                                            var setCodeKey = set.Code ?? string.Empty;
                                            var rarityKey = set.RarityName ?? string.Empty;
                                        }
                                        @if (Model.CollectionEntriesBySetCode.TryGetValue((setCodeKey, rarityKey), out var collectionSummary))
                                        {
                                            var completionStatus = Model.GetCompletionStatus(collectionSummary.Status, collectionSummary.TotalQuantity, setCodeKey, rarityKey) ?? CollectionCompletionStatus.Placeholder;
                                            var isOrdered = collectionSummary.Status == CollectionStatus.Ordered;
                                            var badgeClass = isOrdered ? CollectionStatus.Ordered.GetBadgeClass() : completionStatus.GetBadgeClass();
                                            var badgeLabel = isOrdered ? "Ordered" : completionStatus.GetDisplayName();
                                            <span class="badge @badgeClass">@badgeLabel &times; @collectionSummary.TotalQuantity</span>
                                        }
                                    </td>
                                    <td class="text-nowrap d-none d-md-table-cell">
                                        @{
                                            var isPreferred = Model.PreferredVersion is not null
                                                && string.Equals(Model.PreferredVersion.SetCode, set.Code, StringComparison.OrdinalIgnoreCase)
                                                && (Model.PreferredVersion.RarityName is null || string.Equals(Model.PreferredVersion.RarityName, set.RarityName, StringComparison.OrdinalIgnoreCase));
                                        }
                                        @if (isPreferred)
                                        {
                                            <span class="badge bg-warning text-dark me-1">&#9733; Preferred</span>
                                            <form method="post" asp-page-handler="RemovePreferred" class="d-inline">
                                                <input type="hidden" name="ImageID" value="@(Model.PreferredVersion!.ImageID)" />
                                                <input type="hidden" name="ID" value="@Model.ID" />
                                                @if (!string.IsNullOrEmpty(Model.ReturnURL))
                                                {
                                                    <input type="hidden" name="ReturnURL" value="@Model.ReturnURL" />
                                                }
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Unset</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form method="post" asp-page-handler="SetPreferred" class="d-inline">
                                                <input type="hidden" name="CardID" value="@Model.CurrentCard!.ID" />
                                                <input type="hidden" name="ImageID" value="@primaryImage!.ID" />
                                                <input type="hidden" name="SetCode" value="@set.Code" />
                                                <input type="hidden" name="RarityName" value="@set.RarityName" />
                                                <input type="hidden" name="ID" value="@Model.ID" />
                                                @if (!string.IsNullOrEmpty(Model.ReturnURL))
                                                {
                                                    <input type="hidden" name="ReturnURL" value="@Model.ReturnURL" />
                                                }
                                                <button type="submit" class="btn btn-sm btn-outline-warning">Set as Preferred</button>
                                            </form>
                                        }
                                    </td>
                                    <td class="text-nowrap">
                                        <button type="button"
                                                class="btn btn-sm btn-primary me-1"
                                                onclick="openModal('@(set.Code ?? string.Empty)', '@((set.Name ?? string.Empty).Replace("'", "\\'"))', 'Order', '@((set.RarityName ?? string.Empty).Replace("'", "\\'"))', '@Model.GetTCGDate(set.Code ?? string.Empty)')">
                                            Order
                                        </button>
                                        <button type="button"
                                                class="btn btn-sm btn-success"
                                                onclick="openModal('@(set.Code ?? string.Empty)', '@((set.Name ?? string.Empty).Replace("'", "\\'"))', 'Own', '@((set.RarityName ?? string.Empty).Replace("'", "\\'"))', '@Model.GetTCGDate(set.Code ?? string.Empty)')">
                                            Mark as Owned
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mt-4"><em>No set data available for this card.</em></p>
            }
        </div>
    </div>

    @await Html.PartialAsync("_CollectionEntryModal", new CardCollector.ViewModels.CollectionEntryModalViewModel
    {
        CardID = Model.CurrentCard.ID,
        ImageID = primaryImage.ID,
        PageID = Model.ID,
        PageURL = Url.Page("Card") ?? "/Card",
        ReturnURL = Model.ReturnURL
    })
}

@section Scripts {
    <script src="~/js/collection-entry-modal.js" asp-append-version="true"></script>
}
