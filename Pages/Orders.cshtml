@page
@model OrdersModel
@using CardCollector.Data.Models
@using CardCollector.ViewModels
@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Orders</h1>
    <span class="badge-neutral fs-6">@Model.Orders.Count pending</span>
</div>

@if (Model.Orders.Count == 0)
{
    <div class="alert alert-info text-center py-5">
        <h4>No orders yet</h4>
        <p class="mb-3">Head to <a href="/Discover">Discover</a> to find cards to order.</p>
    </div>
}
else
{
    <div class="list-group mb-4 cc-table-card" id="ordersList">
        @foreach (var order in Model.Orders)
        {
            <partial name="_OrderRow" model="order" />
        }
    </div>
}

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-fullscreen-sm-down modal-dialog-scrollable">
        <div class="modal-content">
            <form method="post" action="/Orders?handler=Edit" id="editForm" class="ajax-form">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="editModalLabel">Edit Order</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="entryID" id="editEntryID" />
                    <partial name="_CollectionFormFields" model='new CollectionFormFieldsViewModel { Prefix = "edit", AcquisitionVisible = true, MarketPriceEditable = true }' />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Mark Owned Modal -->
<div class="modal fade" id="markOwnedModal" tabindex="-1" aria-labelledby="markOwnedModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen-sm-down modal-dialog-scrollable">
        <div class="modal-content">
            <form method="post" asp-page-handler="MarkOwned">
                <div class="modal-header">
                    <h5 class="modal-title" id="markOwnedModalLabel">Add to Collection</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="entryID" id="markOwnedEntryID" />
                    <div class="mb-3">
                        <label class="form-label">Quantity received</label>
                        <input type="hidden" name="quantity" id="markOwnedQuantity" value="1" />
                        <div class="btn-group btn-group-sm w-100" role="group" aria-label="Quantity received">
                            @for (int q = 1; q <= 3; q++)
                            {
                                <button type="button" class="btn @(q == 1 ? "btn-primary" : "btn-outline-secondary")"
                                        data-qty-target="markOwnedQuantity" data-qty-value="@q"
                                        onclick="selectQuantity(this)">@q</button>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/collection-groups.js" asp-append-version="true"></script>
    <script src="~/js/orders.js" asp-append-version="true"></script>
}
