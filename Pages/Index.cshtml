@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="mb-4">Dashboard</h1>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Collection Progress</h5>
        <div class="d-flex justify-content-between mb-2 text-muted small">
            <span>@Model.Stats.CompletedCount.ToString("N0") completed of @Model.Stats.TotalCards.ToString("N0")</span>
            <span>@Model.Stats.PercentCompleted.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%</span>
        </div>
        <div class="progress" style="height: 20px;">
            <div class="progress-bar bg-success"
                 role="progressbar"
                 style="width: @Model.Stats.PercentCompleted.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"
                 aria-valuenow="@Model.Stats.PercentCompleted"
                 aria-valuemin="0"
                 aria-valuemax="100">
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-6 col-md-4">
        <div class="card text-center border-success h-100">
            <div class="card-body">
                <h6 class="card-title text-success text-uppercase">Completed</h6>
                <p class="card-text display-6 fw-bold text-success">@Model.Stats.CompletedCount.ToString("N0")</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card text-center border-warning h-100">
            <div class="card-body">
                <h6 class="card-title text-warning text-uppercase">Ordered</h6>
                <p class="card-text display-6 fw-bold text-warning">@Model.Stats.OrderedCount.ToString("N0")</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card text-center border-secondary h-100">
            <div class="card-body">
                <h6 class="card-title text-secondary text-uppercase">Remaining</h6>
                <p class="card-text display-6 fw-bold text-secondary">@Model.Stats.RemainingCount.ToString("N0")</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-3">
    <div class="col-6 col-md-4">
        <div class="card text-center border-info h-100">
            <div class="card-body">
                <h6 class="card-title text-info text-uppercase">Incomplete Sets</h6>
                <p class="card-text display-6 fw-bold text-info">@Model.Stats.IncompleteSetCount.ToString("N0")</p>
                <p class="card-text text-muted small">Preferred versions with fewer than 3 copies</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card text-center border-danger h-100">
            <div class="card-body">
                <h6 class="card-title text-danger text-uppercase">Placeholder Sets</h6>
                <p class="card-text display-6 fw-bold text-danger">@Model.Stats.PlaceholderSetCount.ToString("N0")</p>
                <p class="card-text text-muted small">Sets with unreplaced placeholders</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card text-center border-primary h-100">
            <div class="card-body">
                <h6 class="card-title text-primary text-uppercase">Wishlisted</h6>
                <p class="card-text display-6 fw-bold text-primary">@Model.Stats.WishlistCount.ToString("N0")</p>
                <p class="card-text text-muted small">Preferred versions not yet owned</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-3">
    <div class="col-6 col-md-4">
        <div class="card text-center h-100">
            <div class="card-body">
                <h6 class="card-title text-muted text-uppercase">Total Cards</h6>
                <p class="card-text display-6 fw-bold">@Model.Stats.TotalCardQuantity.ToString("N0")</p>
                <p class="card-text text-muted small">Physical cards owned</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card text-center border-success h-100">
            <div class="card-body">
                <h6 class="card-title text-success text-uppercase">Total Spent</h6>
                <p class="card-text display-6 fw-bold text-success">
                    @(Model.Stats.TotalSpent.HasValue ? Model.Stats.TotalSpent.Value.ToString("C") : "—")
                </p>
                <p class="card-text text-muted small">Sum of recorded purchase prices</p>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="card text-center border-info h-100">
            <div class="card-body">
                <h6 class="card-title text-info text-uppercase">Current Market Value</h6>
                <p class="card-text display-6 fw-bold text-info">
                    @(Model.Stats.CurrentMarketValue.HasValue ? Model.Stats.CurrentMarketValue.Value.ToString("C") : "—")
                </p>
                <p class="card-text text-muted small">
                    @if (Model.Stats.CurrentMarketValueDate is not null)
                    {
                        <text>As of @Model.Stats.CurrentMarketValueDate</text>
                    }
                    else
                    {
                        <text>Calculate on the <a href="/Stats">Stats page</a></text>
                    }
                </p>
            </div>
        </div>
    </div>
</div>
