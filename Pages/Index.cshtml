@page
@model IndexModel
@using CardCollector.ViewModels
@{
    ViewData["Title"] = "Dashboard";
    var totalPossible = Model.Stats.TotalCards * 3;
    var overallPercent = totalPossible == 0 ? 0 : (Model.Stats.TotalCardQuantity + Model.Stats.OrderedCount) * 100.0 / totalPossible;
}

<h1 class="mb-4">Dashboard</h1>

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-end mb-2">
            <div>
                <h5 class="card-title mb-1">Collection Progress</h5>
                <div class="text-muted small">
                    @Model.Stats.CompletedCount.ToString("N0") complete &middot; @Model.Stats.OrderedCount.ToString("N0") ordered &middot; @Model.Stats.IncompleteSetCount.ToString("N0") in progress
                </div>
            </div>
            <div class="cc-hero-figure">@overallPercent.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%</div>
        </div>
        <div class="d-flex justify-content-between mb-2 text-muted small">
            <span>@Model.Stats.TotalCardQuantity.ToString("N0") copies</span>
            <span>of @Model.Stats.TotalCards.ToString("N0") cards</span>
        </div>
        <div class="progress" style="height: 20px;">
            <div class="progress-bar bg-success"
                 role="progressbar"
                 style="width: @Model.Stats.PercentCompleted.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"
                 aria-valuenow="@Model.Stats.PercentCompleted"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 title="@Model.Stats.CompletedCount.ToString("N0") complete artworks">
            </div>
            <div class="progress-bar bg-warning"
                 role="progressbar"
                 style="width: @Model.Stats.PercentOrdered.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"
                 aria-valuenow="@Model.Stats.PercentOrdered"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 title="@Model.Stats.OrderedCount.ToString("N0") ordered">
            </div>
            <div class="progress-bar bg-info"
                 role="progressbar"
                 style="width: @Model.Stats.PercentIncompleteCopies.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"
                 aria-valuenow="@Model.Stats.PercentIncompleteCopies"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 title="@Model.Stats.IncompleteSetCount.ToString("N0") in progress">
            </div>
        </div>
    </div>
</div>

@{
    var tiles = new[]
    {
        new StatTileViewModel("Completed", Model.Stats.CompletedCount.ToString("N0"), AccentColor: "success"),
        new StatTileViewModel("Incomplete", Model.Stats.IncompleteSetCount.ToString("N0"), AccentColor: "info"),
        new StatTileViewModel("Ordered", Model.Stats.OrderedCount.ToString("N0"), AccentColor: "warning"),
        new StatTileViewModel("Wishlisted", Model.Stats.WishlistCount.ToString("N0"), AccentColor: "primary"),
        new StatTileViewModel("Placeholders", Model.Stats.PlaceholderSetCount.ToString("N0"), AccentColor: "danger"),
        new StatTileViewModel("Remaining", Model.Stats.RemainingCount.ToString("N0"), AccentColor: "secondary"),
        new StatTileViewModel("Total spent", Model.Stats.TotalSpent.HasValue ? Model.Stats.TotalSpent.Value.ToString("C") : "—", AccentColor: "indigo"),
        new StatTileViewModel("Market value", Model.Stats.CurrentMarketValue.HasValue ? Model.Stats.CurrentMarketValue.Value.ToString("C") : "—", AccentColor: "teal"),
    };
}
<div class="row g-3 mb-3">
    @foreach (var tile in tiles.Take(3))
    {
        <div class="col">
            <partial name="_StatTile" model="tile" />
        </div>
    }
</div>
<div class="row g-3 mb-3">
    @foreach (var tile in tiles.Skip(3).Take(3))
    {
        <div class="col">
            <partial name="_StatTile" model="tile" />
        </div>
    }
</div>
<div class="row g-3">
    @foreach (var tile in tiles.Skip(6))
    {
        <div class="col">
            <partial name="_StatTile" model="tile" />
        </div>
    }
</div>
