@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
    var totalPossible = Model.Stats.TotalCards * 3;
    var overallPercent = totalPossible == 0 ? 0 : (Model.Stats.TotalCardQuantity + Model.Stats.OrderedCount) * 100.0 / totalPossible;
}

<h1 class="mb-4">Dashboard</h1>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Collection Progress</h5>
        <div class="d-flex justify-content-between text-muted small">
            <span>@Model.Stats.CompletedCount.ToString("N0") complete &middot; @Model.Stats.OrderedCount.ToString("N0") ordered &middot; @Model.Stats.IncompleteSetCount.ToString("N0") in progress</span>
            <span>@overallPercent.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%</span>
        </div>
        <div class="d-flex justify-content-between mb-2 text-muted small">
            <span>@Model.Stats.TotalCardQuantity.ToString("N0") copies</span>
            <span>of @Model.Stats.TotalCards.ToString("N0") cards</span>
        </div>
        <div class="progress" style="height: 20px;">
            <div class="progress-bar bg-success"
                 role="progressbar"
                 style="width: @Model.Stats.PercentCompleted.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"
                 aria-valuenow="@Model.Stats.PercentCompleted"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 title="@Model.Stats.CompletedCount.ToString("N0") complete artworks">
            </div>
            <div class="progress-bar bg-warning"
                 role="progressbar"
                 style="width: @Model.Stats.PercentOrdered.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"
                 aria-valuenow="@Model.Stats.PercentOrdered"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 title="@Model.Stats.OrderedCount.ToString("N0") ordered">
            </div>
            <div class="progress-bar bg-info"
                 role="progressbar"
                 style="width: @Model.Stats.PercentIncompleteCopies.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"
                 aria-valuenow="@Model.Stats.PercentIncompleteCopies"
                 aria-valuemin="0"
                 aria-valuemax="100"
                 title="@Model.Stats.IncompleteSetCount.ToString("N0") in progress">
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col">
        <div class="card stat-card text-center border-success h-100">
            <div class="card-body p-2">
                <h6 class="card-title text-success-emphasis text-uppercase small">Completed</h6>
                <p class="card-text fs-4 fw-bold text-success-emphasis">@Model.Stats.CompletedCount.ToString("N0")</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card text-center border-info h-100">
            <div class="card-body p-2">
                <h6 class="card-title text-info-emphasis text-uppercase small">Incomplete</h6>
                <p class="card-text fs-4 fw-bold text-info-emphasis">@Model.Stats.IncompleteSetCount.ToString("N0")</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card text-center border-warning h-100">
            <div class="card-body p-2">
                <h6 class="card-title text-warning-emphasis text-uppercase small">Ordered</h6>
                <p class="card-text fs-4 fw-bold text-warning-emphasis">@Model.Stats.OrderedCount.ToString("N0")</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col">
        <div class="card stat-card text-center border-primary h-100">
            <div class="card-body p-2">
                <h6 class="card-title text-primary-emphasis text-uppercase small">Wishlisted</h6>
                <p class="card-text fs-4 fw-bold text-primary-emphasis">@Model.Stats.WishlistCount.ToString("N0")</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card text-center border-danger h-100">
            <div class="card-body p-2">
                <h6 class="card-title text-danger-emphasis text-uppercase small">Placeholders</h6>
                <p class="card-text fs-4 fw-bold text-danger-emphasis">@Model.Stats.PlaceholderSetCount.ToString("N0")</p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card text-center border-secondary h-100">
            <div class="card-body p-2">
                <h6 class="card-title text-secondary-emphasis text-uppercase small">Remaining</h6>
                <p class="card-text fs-4 fw-bold text-secondary-emphasis">@Model.Stats.RemainingCount.ToString("N0")</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col">
        <div class="card stat-card text-center border-cc-indigo h-100">
            <div class="card-body p-2">
                <h6 class="card-title text-cc-indigo text-uppercase small">Total Spent</h6>
                <p class="card-text fs-4 fw-bold text-cc-indigo">
                    @(Model.Stats.TotalSpent.HasValue ? Model.Stats.TotalSpent.Value.ToString("C") : "—")
                </p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card stat-card text-center border-cc-teal h-100">
            <div class="card-body p-2">
                <h6 class="card-title text-cc-teal text-uppercase small">Market Value</h6>
                <p class="card-text fs-4 fw-bold text-cc-teal">
                    @(Model.Stats.CurrentMarketValue.HasValue ? Model.Stats.CurrentMarketValue.Value.ToString("C") : "—")
                </p>
            </div>
        </div>
    </div>
</div>
