@page
@model DiscoverModel
@{
    ViewData["Title"] = "Discover";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Discover</h1>
    @if (!Model.IsComplete)
    {
        <a href="/Discover" class="btn btn-outline-secondary">Skip &rarr;</a>
    }
</div>

@if (Model.IsComplete)
{
    <div class="alert alert-success text-center py-5">
        <h3>All done!</h3>
        <p class="mb-0">You have set a preferred version for every card in the database.</p>
    </div>
}
else if (Model.CurrentCard is not null && Model.CurrentImage is not null)
{
    <div class="row g-4">
        <div class="col-md-4 col-lg-3 text-center">
            <img src="@Model.CurrentImage.ImageURL"
                 alt="@Model.CurrentCard.Name"
                 class="img-fluid rounded shadow"
                 style="max-width: 280px;" />
        </div>
        <div class="col-md-8 col-lg-9">
            <h2>@Model.CurrentCard.Name</h2>
            <p class="text-muted mb-1">
                @Model.CurrentCard.CardType
                @if (!string.IsNullOrEmpty(Model.CurrentCard.Type))
                {
                    <span>/ @Model.CurrentCard.Type</span>
                }
                @if (!string.IsNullOrEmpty(Model.CurrentCard.Attribute))
                {
                    <span> &mdash; @Model.CurrentCard.Attribute</span>
                }
            </p>
            @if (Model.CurrentCard.ATK.HasValue || Model.CurrentCard.DEF.HasValue)
            {
                <p class="text-muted mb-1">
                    @if (Model.CurrentCard.ATK.HasValue)
                    {
                        <span>ATK&nbsp;@Model.CurrentCard.ATK</span>
                    }
                    @if (Model.CurrentCard.DEF.HasValue)
                    {
                        <span class="ms-3">DEF&nbsp;@Model.CurrentCard.DEF</span>
                    }
                    @if (Model.CurrentCard.Level.HasValue)
                    {
                        <span class="ms-3">Level&nbsp;@Model.CurrentCard.Level</span>
                    }
                </p>
            }
            <p class="mt-2">@Model.CurrentCard.Description</p>

            <p class="text-muted mt-3 mb-2 small">Pick the printing you want to collect:</p>

            @if (Model.CurrentCard.CardSets?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="cc-table-head">
                            <tr>
                                <th>Set</th>
                                <th>Code</th>
                                <th>Rarity</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var sortedSets = Model.CurrentCard.CardSets
                                    .OrderBy(s => {
                                        var d = Model.GetTCGDate(s.Code ?? string.Empty);
                                        return string.IsNullOrEmpty(d) ? "9999-99-99" : d;
                                    });
                            }
                            @foreach (var set in sortedSets)
                            {
                                <tr>
                                    <td>@set.Name</td>
                                    <td><code>@set.Code</code></td>
                                    <td>@set.RarityName</td>
                                    <td>
                                        <form method="post" asp-page-handler="SetPreferred">
                                            <input type="hidden" name="CardID" value="@Model.CurrentCard.ID" />
                                            <input type="hidden" name="ImageID" value="@Model.CurrentImage.ID" />
                                            <input type="hidden" name="SetCode" value="@set.Code" />
                                            <input type="hidden" name="RarityName" value="@set.RarityName" />
                                            <button type="submit" class="btn btn-sm btn-primary">
                                                Set as Preferred
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mt-4"><em>No set data available for this card.</em></p>
            }
        </div>
    </div>
}
