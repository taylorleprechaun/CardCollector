@page
@model CollectionModel
@using CardCollector.Data.Models
@using CardCollector.ViewModels
@{
    ViewData["Title"] = "Collection";
    var filterParams = Model.GetFilterParams();
    var clearFiltersURL = $"/Collection{(!string.IsNullOrWhiteSpace(Model.Query) ? $"?query={Uri.EscapeDataString(Model.Query)}" : "")}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Collection</h1>
    <div class="d-flex align-items-center gap-2">
        <span class="badge bg-success fs-6" id="totalCountBadge" data-suffix="owned">@Model.GroupedCards.TotalCount owned</span>
        <a href="/Export?handler=Collection" class="btn btn-outline-secondary btn-sm">Export CSV</a>
    </div>
</div>

<partial name="_SearchForm" model='new SearchFormViewModel
{
    ActiveFilterCount = Model.ActiveFilterCount,
    AutocompleteURL = "?handler=Autocomplete",
    ClearFiltersURL = clearFiltersURL,
    Filters = new AdvancedFiltersViewModel
    {
        AvailableAcquisitionMethods = Model.AvailableAcquisitionMethods,
        AvailableConditions = Model.AvailableConditions,
        AvailableEditions = Model.AvailableEditions,
        AvailableRarityNames = Model.AvailableRarityNames,
        AvailableSetNames = Model.AvailableSetNames,
        CurrentAcquisitionMethod = Model.AcquisitionMethod?.ToString(),
        CurrentCardType = Model.CardType,
        CurrentCheckedOutFilter = Model.CheckedOutFilter,
        CurrentCondition = Model.Condition?.ToString(),
        CurrentEdition = Model.Edition?.ToString(),
        CurrentRarityName = Model.RarityName,
        CurrentSetName = Model.SetName,
        ShowAcquisitionMethod = true,
        ShowCheckedOutFilter = true,
        ShowCondition = true,
        ShowEdition = true
    },
    HasActiveFilters = Model.HasActiveFilters,
    PageSize = Model.PageSize,
    Placeholder = "Search by name, set, or rarity…",
    Query = Model.Query
}' />

@if (!Model.GroupedCards.Items.Any())
{
    <div class="alert alert-info text-center py-5">
        @if (string.IsNullOrEmpty(Model.Query) && !Model.HasActiveFilters)
        {
            <h4>Nothing owned yet</h4>
            <p class="mb-3">Head to <a href="/Orders">Orders</a> to mark cards as owned.</p>
        }
        else
        {
            <span>No cards match your search or filters.</span>
        }
    </div>
}
else
{
    <div class="list-group mb-4" id="collectionList">
        @foreach (var group in Model.GroupedCards.Items)
        {
            <partial name="_CollectionGroupRow" model='new CollectionGroupRowViewModel { Group = group, FilterParams = filterParams, TCGDate = Model.GetTCGDate(group.SetCode) }' />
        }
    </div>

    <partial name="_Pagination" model='new PaginationViewModel { AriaLabel = "Collection pagination", PageName = "Collection", PageNumber = Model.PageNumber, PageSize = Model.PageSize, Query = Model.Query, TotalPages = Model.GroupedCards.TotalPages, HasPreviousPage = Model.GroupedCards.HasPreviousPage, HasNextPage = Model.GroupedCards.HasNextPage, AdditionalParams = Model.GetPaginationParams() }' />
}

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen-sm-down">
        <div class="modal-content">
            <form method="post" action="/Collection?handler=Edit&@filterParams" id="editForm" class="ajax-form">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="editModalLabel">Edit Entry</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="entryID" id="editEntryID" />
                    <partial name="_CollectionFormFields" model='new CollectionFormFieldsViewModel { Prefix = "edit", AcquisitionVisible = true, MarketPriceEditable = false }' />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Purchase Modal -->
<div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen-sm-down">
        <div class="modal-content">
            <form method="post" action="/Collection?handler=AddPurchase&@filterParams" id="addForm" class="ajax-form">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title" id="addModalLabel">Add Purchase</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="cardID" id="addCardID" />
                    <input type="hidden" name="imageID" id="addImageID" />
                    <input type="hidden" name="setCode" id="addSetCode" />

                    <partial name="_AddToCollectionFormFields" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Add</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/collection-groups.js" asp-append-version="true"></script>
    <script src="~/js/collection.js" asp-append-version="true"></script>
}
