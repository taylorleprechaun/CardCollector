@page
@model CollectionModel
@using CardCollector.Data.Models
@{
    ViewData["Title"] = "Collection";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Collection</h1>
    <div class="d-flex align-items-center gap-2">
        <span class="badge bg-success fs-6">@Model.GroupedCards.TotalCount owned</span>
        <a href="/Export?handler=Collection" class="btn btn-outline-secondary btn-sm">Export CSV</a>
    </div>
</div>

<partial name="_SearchBar" model='new SearchBarViewModel("Search by name, set, or rarity…", "?handler=Autocomplete", Model.PageSize, Model.Query)' />

@if (!Model.GroupedCards.Items.Any())
{
    <div class="alert alert-info text-center py-5">
        @if (string.IsNullOrEmpty(Model.Query))
        {
            <h4>Nothing owned yet</h4>
            <p class="mb-3">Head to <a href="/Orders">Orders</a> to mark cards as owned.</p>
        }
        else
        {
            <span>No cards match &ldquo;@Model.Query&rdquo;.</span>
        }
    </div>
}
else
{
    <div class="list-group mb-4" id="collectionList">
        @{int groupIDx = 0;}
        @foreach (var group in Model.GroupedCards.Items)
        {
            var collapseId = "group-" + groupIDx;
            groupIDx++;
            var status = group.CompletionStatus;

            <div class="list-group-item p-0">
                <!-- Toggle row -->
                <div class="list-group-item-action d-flex align-items-center gap-3 py-2 px-3 border-0 list-group-toggle"
                     role="button"
                     data-bs-toggle="collapse"
                     data-bs-target="#@collapseId"
                     aria-expanded="false"
                     aria-controls="@collapseId">
                    <partial name="_CardThumbnail" model='new CardThumbnailViewModel(group.ImageURLSmall, group.CardName)' />
                    <div class="flex-grow-1 min-width-0">
                        <div class="fw-semibold">@group.CardName</div>
                        <div class="text-muted small">
                            @group.SetName &middot; @group.SetCode &middot; @group.RarityCode
                        </div>
                        <div class="text-muted small">&times;@group.TotalQuantity</div>
                    </div>
                    @if (status == CollectionCompletionStatus.Complete)
                    {
                        <span class="badge bg-success flex-shrink-0">Complete</span>
                    }
                    else if (status == CollectionCompletionStatus.Incomplete)
                    {
                        <span class="badge bg-warning text-dark flex-shrink-0">Incomplete</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary flex-shrink-0">Placeholder</span>
                    }
                    <span class="chevron flex-shrink-0 text-muted ms-1">&#9658;</span>
                </div>

                <!-- Expanded entries -->
                <div class="collapse border-top" id="@collapseId">
                    <div class="p-3 ps-4">
                        <table class="table table-sm mb-3">
                            <thead class="table-light">
                                <tr>
                                    <th>Condition</th>
                                    <th>Edition</th>
                                    <th>Acquisition</th>
                                    <th>Purchase Date</th>
                                    <th>Qty</th>
                                    <th>Purchase Price</th>
                                    <th>Market Price</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in group.Entries)
                                {
                                    <tr>
                                        <td>
                                            @if (entry.IsPlaceholder)
                                            {
                                                <span class="badge bg-secondary me-1">Placeholder</span>
                                            }
                                            @if (entry.Condition.HasValue)
                                            {
                                                @entry.Condition.GetDisplayName()
                                            }
                                            else
                                            {
                                                <span class="text-muted">&mdash;</span>
                                            }
                                        </td>
                                        <td>
                                            @if (entry.Edition.HasValue)
                                            {
                                                @entry.Edition.GetDisplayName()
                                            }
                                            else
                                            {
                                                <span class="text-muted">&mdash;</span>
                                            }
                                        </td>
                                        <td>
                                            @if (entry.AcquisitionMethod.HasValue)
                                            {
                                                @entry.AcquisitionMethod.GetDisplayName()
                                            }
                                            else
                                            {
                                                <span class="text-muted">&mdash;</span>
                                            }
                                        </td>
                                        <td class="text-muted small">
                                            @if (entry.PurchaseDate.HasValue)
                                            {
                                                @entry.PurchaseDate.Value.ToString("MMM d, yyyy")
                                            }
                                            else
                                            {
                                                <span>&mdash;</span>
                                            }
                                        </td>
                                        <td>&times;@entry.Quantity</td>
                                        <td>
                                            @if (entry.PurchasePrice.HasValue)
                                            {
                                                <span>$@entry.PurchasePrice.Value.ToString("F2")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">&mdash;</span>
                                            }
                                        </td>
                                        <td>
                                            @if (entry.MarketPriceAtEntry.HasValue)
                                            {
                                                <span>$@entry.MarketPriceAtEntry.Value.ToString("F2")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">&mdash;</span>
                                            }
                                        </td>
                                        <td class="text-nowrap">
                                            <button type="button" class="btn btn-sm btn-outline-secondary"
                                                    onclick="openEditModal(
                                                        @entry.EntryID,
                                                        @entry.Quantity,
                                                        '@(entry.Condition.HasValue ? entry.Condition.Value.ToString() : "")',
                                                        '@(entry.Edition.HasValue ? entry.Edition.Value.ToString() : "")',
                                                        '@(entry.AcquisitionMethod.HasValue ? entry.AcquisitionMethod.Value.ToString() : "")',
                                                        '@(entry.PurchaseDate.HasValue ? entry.PurchaseDate.Value.ToString("yyyy-MM-dd") : "")',
                                                        '@(entry.PurchasePrice.HasValue ? entry.PurchasePrice.Value.ToString("F2") : "")',
                                                        '@(entry.MarketPriceAtEntry.HasValue ? entry.MarketPriceAtEntry.Value.ToString("F2") : "")',
                                                        '@entry.RarityName.Replace("'", "\\'")'" >
                                                Edit
                                            </button>
                                            <form method="post" asp-page-handler="Delete" class="d-inline ms-1"
                                                  onsubmit="return confirm('Remove this entry from your collection?')">
                                                <input type="hidden" name="entryID" value="@entry.EntryID" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <button type="button" class="btn btn-sm btn-outline-primary"
                                data-card-id="@group.CardID"
                                data-image-id="@group.ImageID"
                                data-rarity-name="@group.RarityName"
                                data-rarities="@string.Join(",", group.AvailableRarities)"
                                data-set-code="@group.SetCode"
                                onclick="openAddModal(this)">
                            + Purchase
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <partial name="_Pagination" model='new PaginationViewModel { AriaLabel = "Collection pagination", PageName = "Collection", PageNumber = Model.PageNumber, PageSize = Model.PageSize, Query = Model.Query, TotalPages = Model.GroupedCards.TotalPages, HasPreviousPage = Model.GroupedCards.HasPreviousPage, HasNextPage = Model.GroupedCards.HasNextPage }' />
}

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="Edit">
                <div class="modal-header">
                    <h5 class="modal-title" id="editModalLabel">Edit Entry</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="entryID" id="editEntryID" />

                    <div class="mb-3">
                        <label class="form-label">Rarity</label>
                        <input type="text" name="rarityName" id="editRarityName" class="form-control" placeholder="e.g. Ultra Rare" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Quantity</label>
                        <input type="number" name="quantity" id="editQuantity" min="1" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Condition</label>
                        <select name="condition" id="editCondition"
                                asp-items="Html.GetEnumSelectList<CardCondition>()"
                                class="form-select">
                            <option value="">-- Select condition --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Edition</label>
                        <select name="edition" id="editEdition"
                                asp-items="Html.GetEnumSelectList<CardEdition>()"
                                class="form-select">
                            <option value="">-- Select edition --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">How did you get it?</label>
                        <select name="acquisitionMethod" id="editAcquisition"
                                asp-items="Html.GetEnumSelectList<AcquisitionMethod>()"
                                class="form-select">
                            <option value="">-- Select --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Purchase Date</label>
                        <input type="date" name="purchaseDate" id="editPurchaseDate" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Purchase Price ($)</label>
                        <input type="number" step="0.01" min="0" name="purchasePrice" id="editPurchasePrice"
                               class="form-control" placeholder="0.00" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            Market Price ($)
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-2"
                                    onclick="document.getElementById('editMarketPriceAtEntry').value = document.getElementById('editPurchasePrice').value"
                                    title="Copy from purchase price">
                                Same as purchase
                            </button>
                        </label>
                        <input type="number" step="0.01" min="0" name="marketPriceAtEntry" id="editMarketPriceAtEntry"
                               class="form-control" placeholder="0.00" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Purchase Modal -->
<div class="modal fade" id="addModal" tabindex="-1" aria-labelledby="addModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-page-handler="AddPurchase">
                <div class="modal-header">
                    <h5 class="modal-title" id="addModalLabel">Add Purchase</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="cardID" id="addCardID" />
                    <input type="hidden" name="imageID" id="addImageID" />
                    <input type="hidden" name="setCode" id="addSetCode" />

                    <div class="mb-3">
                        <label class="form-label">Rarity</label>
                        <select name="rarityName" id="addRarityName" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Quantity</label>
                        <input type="number" name="quantity" id="addQuantity" min="1" value="1" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Condition</label>
                        <select name="condition" id="addCondition"
                                asp-items="Html.GetEnumSelectList<CardCondition>()"
                                class="form-select">
                            <option value="">-- Select condition --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Edition</label>
                        <select name="edition" id="addEdition"
                                asp-items="Html.GetEnumSelectList<CardEdition>()"
                                class="form-select">
                            <option value="">-- Select edition --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">How did you get it?</label>
                        <select name="acquisitionMethod" id="addAcquisition"
                                asp-items="Html.GetEnumSelectList<AcquisitionMethod>()"
                                class="form-select">
                            <option value="">-- Select --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Purchase Date</label>
                        <input type="date" name="purchaseDate" id="addPurchaseDate" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Purchase Price ($)</label>
                        <input type="number" step="0.01" min="0" name="purchasePrice" id="addPurchasePrice"
                               class="form-control" placeholder="0.00" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">
                            Market Price ($)
                            <button type="button" class="btn btn-sm btn-outline-secondary ms-2"
                                    onclick="document.getElementById('addMarketPriceAtEntry').value = document.getElementById('addPurchasePrice').value"
                                    title="Copy from purchase price">
                                Same as purchase
                            </button>
                        </label>
                        <input type="number" step="0.01" min="0" name="marketPriceAtEntry" id="addMarketPriceAtEntry"
                               class="form-control" placeholder="0.00" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Add</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .chevron { transition: transform 0.2s ease; display: inline-block; font-size: 0.75rem; }
        .list-group-toggle:not(.collapsed) .chevron { transform: rotate(90deg); }
    </style>
    <script>
        function openEditModal(entryID, qty, condition, edition, acquisition, purchaseDate, purchasePrice, marketPriceAtEntry, rarityName) {
            document.getElementById('editEntryID').value = entryID;
            document.getElementById('editRarityName').value = rarityName || '';
            document.getElementById('editQuantity').value = qty;
            setSelect('editCondition', condition);
            setSelect('editEdition', edition);
            setSelect('editAcquisition', acquisition);
            document.getElementById('editPurchaseDate').value = purchaseDate;
            document.getElementById('editPurchasePrice').value = purchasePrice;
            document.getElementById('editMarketPriceAtEntry').value = marketPriceAtEntry;
            new bootstrap.Modal(document.getElementById('editModal')).show();
        }

        function openAddModal(btn) {
            document.getElementById('addCardID').value = btn.dataset.cardId;
            document.getElementById('addImageID').value = btn.dataset.imageId;
            document.getElementById('addSetCode').value = btn.dataset.setCode;

            const raritySelect = document.getElementById('addRarityName');
            const rarities = btn.dataset.rarities ? btn.dataset.rarities.split(',').filter(r => r) : [];
            raritySelect.innerHTML = '';
            rarities.forEach(r => {
                const opt = document.createElement('option');
                opt.value = r;
                opt.textContent = r;
                if (r === btn.dataset.rarityName) opt.selected = true;
                raritySelect.appendChild(opt);
            });
            document.getElementById('addQuantity').value = 1;
            setSelect('addCondition', '');
            setSelect('addEdition', '');
            setSelect('addAcquisition', '');
            document.getElementById('addPurchaseDate').value = '';
            document.getElementById('addPurchasePrice').value = '';
            document.getElementById('addMarketPriceAtEntry').value = '';
            new bootstrap.Modal(document.getElementById('addModal')).show();
        }

        function setSelect(id, value) {
            const sel = document.getElementById(id);
            sel.value = value;
        }
    </script>
}
