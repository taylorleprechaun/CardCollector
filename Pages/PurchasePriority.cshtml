@page
@model PurchasePriorityModel
@using CardCollector.ViewModels
@{
    ViewData["Title"] = "Purchase Priority";
    var remainingBudget = Model.TotalBudget.HasValue ? Model.TotalBudget.Value - Model.FullPlan.TotalCost : (decimal?)null;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Purchase Priority</h1>
</div>

<p class="text-muted mb-4">
    Wishlist printings ranked so you can complete playsets before the next price run — printings that are one of only 1-2 foil prints a card has ever had, sitting 5+ years without a reprint, are ranked first. Filter by budget, card count, or a per-card price cap.
</p>

<form method="get" class="mb-4">
    <input type="hidden" name="pageNumber" value="1" />
    <div class="row g-2 align-items-end mb-2">
        <div class="col-auto">
            <label for="totalBudget" class="form-label small mb-1">Total Budget</label>
            <input type="number" step="0.01" min="0" class="form-control form-control-sm" style="width: 140px;"
                   id="totalBudget" name="totalBudget" value="@Model.TotalBudget" />
        </div>
        <div class="col-auto">
            <label for="maxCards" class="form-label small mb-1">Max Cards</label>
            <input type="number" min="1" class="form-control form-control-sm" style="width: 110px;"
                   id="maxCards" name="maxCards" value="@Model.MaxCards" />
        </div>
        <div class="col-auto">
            <label for="maxPricePerCard" class="form-label small mb-1">Max Price Per Card</label>
            <input type="number" step="0.01" min="0" class="form-control form-control-sm" style="width: 140px;"
                   id="maxPricePerCard" name="maxPricePerCard" value="@Model.MaxPricePerCard" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary btn-sm">Apply</button>
            <a href="/PurchasePriority" class="btn btn-outline-secondary btn-sm">Clear</a>
        </div>
    </div>
    <div class="row g-2 align-items-end">
        <div class="col-12 col-sm">
            <label for="query" class="form-label small mb-1">Search</label>
            <input type="search" class="form-control form-control-sm" id="query" name="query"
                   value="@Model.Query" placeholder="Search by name, set, or rarity…" />
        </div>
        <div class="col-auto">
            <label for="pageSize" class="form-label small mb-1">Page Size</label>
            <select name="pageSize" id="pageSize" class="form-select form-select-sm">
                @foreach (var size in new[] { 10, 25, 50, 100 })
                {
                    @if (Model.PageSize == size)
                    {
                        <option value="@size" selected>@size per page</option>
                    }
                    else
                    {
                        <option value="@size">@size per page</option>
                    }
                }
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary btn-sm">Search</button>
        </div>
    </div>
</form>

@{
    var tiles = new[]
    {
        new StatTileViewModel("Items", Model.FullPlan.Items.Count.ToString("N0")),
        new StatTileViewModel("Total Cost", Model.FullPlan.TotalCost.ToString("C")),
        new StatTileViewModel("Remaining Budget", remainingBudget.HasValue ? remainingBudget.Value.ToString("C") : "—")
    };
}
<div class="row g-3 mb-3">
    @foreach (var tile in tiles)
    {
        <div class="col">
            <partial name="_StatTile" model="tile" />
        </div>
    }
</div>

@if (Model.FullPlan.Items.Count == 0)
{
    <div class="alert alert-info text-center py-5">
        <h4>No purchase priority candidates</h4>
        <p class="mb-3">Add preferred versions via <a href="/Discover">Discover</a>, or loosen your budget/price filters above.</p>
    </div>
}
else
{
    <div class="mb-4">
        <label for="massEntryText" class="form-label small mb-1">TCGPlayer Mass Entry (full plan, not affected by the search box above)</label>
        <textarea id="massEntryText" class="form-control font-monospace small" rows="8" readonly>@Model.MassEntryText</textarea>
        <button type="button" id="copyMassEntryBtn" class="btn btn-outline-secondary btn-sm mt-2">Copy for TCGPlayer</button>
    </div>

    @if (Model.Results.Items.Count == 0)
    {
        <div class="alert alert-info text-center py-5">
            <span>No plan items match your search.</span>
        </div>
    }
    else
    {
        <div class="table-responsive cc-table-card">
            <table class="table table-hover align-middle">
                <thead class="cc-table-head">
                    <tr>
                        <th style="width: 60px;"></th>
                        <th>Card</th>
                        <th>Set</th>
                        <th>Rarity</th>
                        <th class="d-none d-md-table-cell">Qty Needed</th>
                        <th class="d-none d-md-table-cell">Price</th>
                        <th class="d-none d-md-table-cell">Line Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Results.Items)
                    {
                        <tr>
                            <td>
                                <partial name="_CardThumbnail" model='new CardThumbnailViewModel(item.ImageURLSmall, item.CardName)' />
                            </td>
                            <td class="fw-semibold">
                                <a href="/Card?id=@item.CardID&imageID=@item.ImageID" class="text-body">@item.CardName</a>
                                @if (!string.IsNullOrEmpty(item.PrintingDate))
                                {
                                    <span class="d-block text-muted small fw-normal">Foils: @item.FoilCount &middot; Printed: @item.PrintingDate</span>
                                }
                            </td>
                            <td>
                                <span class="d-block">@item.SetName</span>
                                <code class="text-muted small">@item.SetCode</code>
                            </td>
                            <td>
                                @item.RarityName
                                @if (item.HasAmbiguousSetCode)
                                {
                                    <span class="badge bg-warning text-dark ms-1"
                                          title="This card has another rarity under the same set code. TCGPlayer's mass entry can't tell them apart by name/set alone — double-check the printing it adds matches this rarity.">
                                        Verify rarity
                                    </span>
                                }
                            </td>
                            <td class="d-none d-md-table-cell">@item.QuantityNeeded</td>
                            <td class="d-none d-md-table-cell">
                                @if (item.Price.HasValue)
                                {
                                    <span>$@item.Price.Value.ToString("F2")</span>
                                }
                                else
                                {
                                    <span class="text-muted">&mdash;</span>
                                }
                            </td>
                            <td class="d-none d-md-table-cell">$@item.LineTotal.ToString("F2")</td>
                            <td class="text-nowrap">
                                <button type="button" class="btn btn-sm btn-primary"
                                        data-card-id="@item.CardID"
                                        data-image-id="@item.ImageID"
                                        data-set-code="@item.SetCode"
                                        data-rarity-name="@item.RarityName"
                                        data-card-name="@item.CardName"
                                        data-set-name="@item.SetName"
                                        data-quantity-needed="@item.QuantityNeeded"
                                        data-price="@item.Price"
                                        onclick="openPurchaseModal(this)">
                                    Order
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" model='new PaginationViewModel { AriaLabel = "Purchase priority pagination", PageName = "PurchasePriority", PageNumber = Model.PageNumber, PageSize = Model.PageSize, Query = Model.Query, TotalPages = Model.Results.TotalPages, HasPreviousPage = Model.Results.HasPreviousPage, HasNextPage = Model.Results.HasNextPage, AdditionalParams = Model.GetPaginationParams() }' />
    }
}

<partial name="_PurchaseLinesModal" />

@section Scripts {
    <script src="~/js/purchase-priority.js" asp-append-version="true"></script>
}
