@model CardCollector.ViewModels.CollectionFormFieldsViewModel
@using CardCollector.Data.Models

<div class="row g-2 mb-2">
    <div class="col-4">
        <label class="form-label">Rarity</label>
        <input type="hidden" name="rarityName" id="@(Model.Prefix)RarityName" />
        <div id="@(Model.Prefix)RarityDisplay" class="form-control-plaintext form-control-sm"></div>
    </div>
    <div class="col-4">
        <label class="form-label">Condition</label>
        <select name="condition" id="@(Model.Prefix)Condition"
                asp-items="Html.GetEnumSelectList<CardCondition>()"
                class="form-select form-select-sm">
            <option value="">-- Condition --</option>
        </select>
    </div>
    <div class="col-4">
        <label class="form-label">Edition</label>
        <select name="edition" id="@(Model.Prefix)Edition"
                asp-items="Html.GetEnumSelectList<CardEdition>()"
                class="form-select form-select-sm">
            <option value="">-- Edition --</option>
        </select>
    </div>
</div>
<div class="row g-2 mb-2 align-items-end">
    <div class="col-4">
        <label class="form-label">Quantity</label>
        <input type="number" name="quantity" id="@(Model.Prefix)Quantity" min="1" value="1" class="form-control form-control-sm" />
    </div>
    <div class="col-4" id="@(Model.Prefix)AcquisitionGroup" style="display:@(Model.AcquisitionVisible ? "block" : "none");">
        <label class="form-label">Acquisition</label>
        <select name="acquisitionMethod" id="@(Model.Prefix)Acquisition"
                asp-items="Html.GetEnumSelectList<AcquisitionMethod>()"
                class="form-select form-select-sm">
            <option value="">-- Select --</option>
        </select>
    </div>
    @if (Model.ShowPreferred)
    {
        <div class="col-4 d-flex align-items-end pb-1">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="setAsPreferred" id="@(Model.Prefix)SetAsPreferred" value="true" checked />
                <label class="form-check-label" for="@(Model.Prefix)SetAsPreferred">Preferred</label>
            </div>
        </div>
    }
</div>
<div class="row g-2">
    <div class="col-4">
        <label class="form-label">Purchase Date</label>
        <input type="date" name="purchaseDate" id="@(Model.Prefix)PurchaseDate" class="form-control form-control-sm" />
    </div>
    <div class="col-4">
        <label class="form-label">Purchase Price ($)</label>
        <input type="number" step="0.01" min="0" name="purchasePrice" id="@(Model.Prefix)PurchasePrice"
               class="form-control form-control-sm" placeholder="0.00" />
    </div>
    <div class="col-4">
        <label class="form-label d-flex align-items-center gap-1">
            Market Price ($)
            <button type="button" class="btn btn-sm btn-link p-0 text-secondary"
                    onclick="document.getElementById('@(Model.Prefix)MarketPrice').value = document.getElementById('@(Model.Prefix)PurchasePrice').value"
                    title="Copy from purchase price">&#x2194;</button>
        </label>
        <input type="number" step="0.01" min="0" name="marketPriceAtEntry" id="@(Model.Prefix)MarketPrice"
               class="form-control form-control-sm" placeholder="0.00" />
    </div>
</div>
