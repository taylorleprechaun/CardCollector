@model CardCollector.ViewModels.CollectionEntryModalViewModel

<div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-fullscreen-sm-down">
        <div class="modal-content">
            <form id="orderForm" method="post" data-page-url="@Model.PageURL">
                <div class="modal-header">
                    <h5 class="modal-title" id="orderModalLabel"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CardID" value="@Model.CardID" />
                    <input type="hidden" name="ImageID" value="@Model.ImageID" />
                    <input type="hidden" name="SetCode" id="atcSetCode" />
                    @if (Model.PageID.HasValue)
                    {
                        <input type="hidden" name="ID" value="@Model.PageID.Value" />
                    }
                    @if (!string.IsNullOrEmpty(Model.ReturnURL))
                    {
                        <input type="hidden" name="ReturnURL" value="@Model.ReturnURL" />
                    }

                    <p class="text-muted mb-3">
                        Set: <strong id="atcSetNameLabel"></strong>
                    </p>

                    <partial name="_AddToCollectionFormFields" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="modalSubmitBtn" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>
