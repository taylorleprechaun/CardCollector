@model CardCollector.ViewModels.CollectionEntryModalViewModel

<div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="orderForm" method="post" data-page-url="@Model.PageUrl">
                <div class="modal-header">
                    <h5 class="modal-title" id="orderModalLabel"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CardID" value="@Model.CardID" />
                    <input type="hidden" name="ImageID" value="@Model.ImageID" />
                    <input type="hidden" name="SetCode" id="atcSetCode" />
                    @if (Model.PageID.HasValue)
                    {
                        <input type="hidden" name="Id" value="@Model.PageID.Value" />
                    }
                    @if (!string.IsNullOrEmpty(Model.ReturnUrl))
                    {
                        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                    }

                    <p class="text-muted mb-3">
                        Set: <strong id="atcSetNameLabel"></strong>
                    </p>

                    <partial name="_AddToCollectionFormFields" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="modalSubmitBtn" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function openModal(setCode, setName, action, rarityName) {
        const isOrder = action === 'Order';
        const form = document.getElementById('orderForm');

        document.getElementById('atcSetCode').value = setCode;
        document.getElementById('atcSetNameLabel').textContent = setName;
        document.getElementById('orderModalLabel').textContent = isOrder ? 'Order Printing' : 'Already Own This Printing';

        const submitBtn = document.getElementById('modalSubmitBtn');
        submitBtn.textContent = isOrder ? 'Confirm Order' : 'Mark as Owned';
        submitBtn.className = isOrder ? 'btn btn-primary' : 'btn btn-success';

        const raritySelect = document.getElementById('atcRarityName');
        raritySelect.innerHTML = '';
        if (rarityName) {
            const opt = document.createElement('option');
            opt.value = rarityName;
            opt.textContent = rarityName;
            raritySelect.appendChild(opt);
        }

        document.getElementById('atcAcquisitionGroup').style.display = isOrder ? 'none' : 'block';
        document.getElementById('atcCondition').value = '';
        document.getElementById('atcEdition').value = '';
        document.getElementById('atcAcquisition').value = '';
        document.getElementById('atcQuantity').value = 1;
        document.getElementById('atcPurchaseDate').value = '';
        document.getElementById('atcPurchasePrice').value = '';
        document.getElementById('atcMarketPrice').value = '';
        document.getElementById('atcSetAsPreferred').checked = true;

        form.action = form.dataset.pageUrl + '?handler=' + action;

        new bootstrap.Modal(document.getElementById('orderModal')).show();
    }
</script>
