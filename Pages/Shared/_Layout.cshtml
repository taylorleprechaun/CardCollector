@inject CardCollector.Services.ICardService CardService
<!DOCTYPE html>
<html lang="en">
<head>
    <script>
        (function () {
            var stored = localStorage.getItem('cc-theme');
            document.documentElement.setAttribute('data-bs-theme', stored === 'dark' ? 'dark' : 'light');
        })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Card Collector</title>
    <link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
    @{
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
        var isDashboard = currentPage == "/Index";
        var isCatalog = currentPage is "/Browse" or "/Discover" or "/NewPrintings";
        var isCollection = currentPage is "/Collection" or "/CheckedOut";
        var isShopping = currentPage is "/Wishlist" or "/BuyList" or "/Cart" or "/Orders";
        var isInsights = currentPage is "/Stats" or "/EditionAudit";
        (int Count, decimal Total) cartSummary = User.Identity?.IsAuthenticated == true
            ? await CardService.GetCartSummaryAsync()
            : (0, 0m);
    }
    <nav class="navbar navbar-expand-lg navbar-dark cc-navbar sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/"><img src="~/favicon.svg" alt="" class="cc-brand-icon me-1" />Card Collector</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <div class="navbar-nav me-auto ms-lg-3">
                        <a class="nav-link @(isDashboard ? "active" : "")" href="/"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>

                        <div class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(isCatalog ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-search me-1"></i>Catalog
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item @(currentPage == "/Browse" ? "active" : "")" href="/Browse">Browse</a></li>
                                <li><a class="dropdown-item @(currentPage == "/Discover" ? "active" : "")" href="/Discover">Discover</a></li>
                                <li><a class="dropdown-item @(currentPage == "/NewPrintings" ? "active" : "")" href="/NewPrintings">New Printings</a></li>
                            </ul>
                        </div>

                        <div class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(isCollection ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-collection me-1"></i>Collection
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item @(currentPage == "/Collection" ? "active" : "")" href="/Collection">Collection</a></li>
                                <li><a class="dropdown-item @(currentPage == "/CheckedOut" ? "active" : "")" href="/CheckedOut">Checked Out</a></li>
                            </ul>
                        </div>

                        <div class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(isShopping ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-bag me-1"></i>Shopping
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item @(currentPage == "/Wishlist" ? "active" : "")" href="/Wishlist">Wishlist</a></li>
                                <li><a class="dropdown-item @(currentPage == "/BuyList" ? "active" : "")" href="/BuyList">Buy List</a></li>
                                <li><a class="dropdown-item @(currentPage == "/Cart" ? "active" : "")" href="/Cart">Cart</a></li>
                                <li><a class="dropdown-item @(currentPage == "/Orders" ? "active" : "")" href="/Orders">Orders</a></li>
                            </ul>
                        </div>

                        <div class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(isInsights ? "active" : "")" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-bar-chart-line me-1"></i>Insights
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item @(currentPage == "/Stats" ? "active" : "")" href="/Stats">Stats</a></li>
                                <li><a class="dropdown-item @(currentPage == "/EditionAudit" ? "active" : "")" href="/EditionAudit">Edition Audit</a></li>
                            </ul>
                        </div>
                    </div>
                    <div class="navbar-nav mt-2 mt-lg-0 align-items-lg-center">
                        <a href="/Cart" id="navCartBadge" title="@(cartSummary.Total > 0 ? $"${cartSummary.Total:F2} staged" : "")"
                           class="btn btn-sm btn-outline-light me-lg-2 mb-2 mb-lg-0 @(cartSummary.Count == 0 ? "d-none" : "")">
                            <i class="bi bi-cart"></i> Cart
                            <span class="badge bg-danger ms-1" id="navCartCount">@cartSummary.Count</span>
                        </a>
                        <button type="button" class="btn btn-sm cc-theme-toggle me-lg-2 mb-2 mb-lg-0" id="themeToggleBtn" aria-label="Toggle dark mode">
                            <i class="bi bi-moon-stars-fill"></i>
                            <i class="bi bi-sun-fill"></i>
                        </button>
                        <form method="post" asp-page="/Logout">
                            <button type="submit" class="btn btn-outline-light btn-sm">Log Out</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    </nav>
    <main class="container mt-4 mb-5">
        @if (TempData["Error"] is string errorMsg)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Warning"] is string warningMsg)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                @warningMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Success"] is string successMsg)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @RenderBody()
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="~/js/enums.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
