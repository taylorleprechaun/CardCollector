@model int
@using CardCollector.Data.Models
@{
    var i = Model;
}
<div class="position-relative pe-5 pb-3 mb-3 border-bottom purchase-line" data-line-index="@i">
    <button type="button" class="btn btn-sm btn-outline-danger rounded-circle position-absolute top-0 end-0 purchase-line-remove"
            onclick="removePurchaseLine(this)" title="Remove line" aria-label="Remove line">
        <i class="bi bi-x-lg"></i>
    </button>
    <div class="row g-3 mb-3">
        <div class="col-12 col-sm-4">
            <label class="form-label">Condition</label>
            <select name="Lines[@i].Condition" id="lineCondition@(i)"
                    asp-items="Html.GetEnumSelectList<CardCondition>()"
                    class="form-select form-select-sm">
                <option value="">-- Condition --</option>
            </select>
        </div>
        <div class="col-12 col-sm-4">
            <label class="form-label">Edition</label>
            <select name="Lines[@i].Edition" id="lineEdition@(i)"
                    asp-items="Html.GetEnumSelectList<CardEdition>()"
                    class="form-select form-select-sm">
                <option value="">-- Edition --</option>
            </select>
        </div>
        <div class="col-12 col-sm-4">
            <label class="form-label">Quantity</label>
            <input type="hidden" name="Lines[@i].Quantity" id="lineQuantity@(i)" value="1" />
            <div class="btn-group btn-group-sm w-100" role="group" aria-label="Quantity">
                @for (var q = 1; q <= 3; q++)
                {
                    <button type="button" class="btn @(q == 1 ? "btn-primary" : "btn-outline-secondary")"
                            data-qty-target="lineQuantity@(i)" data-qty-value="@q"
                            onclick="selectQuantity(this)">@q</button>
                }
            </div>
        </div>
    </div>
    <div class="row g-3">
        <div class="col-12 col-sm-4">
            <label class="form-label d-flex align-items-center gap-1">
                Purchase Date
                <button type="button" class="btn btn-sm btn-link p-0 text-secondary-emphasis"
                        onclick="setPickerDate('linePurchaseDate@(i)', new Date())" title="Set to today">Today</button>
            </label>
            <input type="date" name="Lines[@i].PurchaseDate" id="linePurchaseDate@(i)" class="form-control form-control-sm cc-date-picker" />
        </div>
        <div class="col-12 col-sm-4">
            <label class="form-label">Price ($)</label>
            <input type="number" step="0.01" min="0" name="Lines[@i].PurchasePrice" id="linePrice@(i)"
                   class="form-control form-control-sm" placeholder="0.00" />
        </div>
        <div class="col-12 col-sm-4">
            <label class="form-label d-flex align-items-center gap-1">
                Market Price ($)
                <button type="button" class="btn btn-sm btn-link p-0 text-secondary-emphasis"
                        onclick="document.getElementById('lineMarketPrice@(i)').value = document.getElementById('linePrice@(i)').value"
                        title="Copy from purchase price">&#x2194;</button>
            </label>
            <input type="number" step="0.01" min="0" name="Lines[@i].MarketPriceAtEntry" id="lineMarketPrice@(i)"
                   class="form-control form-control-sm" placeholder="0.00" />
        </div>
    </div>
</div>
