<div class="modal fade" id="wishlistOrderModal" tabindex="-1" aria-labelledby="wishlistOrderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <form id="wishlistOrderForm" method="post" class="ajax-form">
                <div class="modal-header">
                    <h5 class="modal-title" id="wishlistOrderModalLabel">Order <span id="woCardName"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="cardID" id="woCardID" />
                    <input type="hidden" name="imageID" id="woImageID" />
                    <input type="hidden" name="setCode" id="woSetCode" />
                    <input type="hidden" name="rarityName" id="woRarityName" />
                    <input type="hidden" name="marketPrice" id="woMarketPrice" />

                    <p class="text-muted mb-3">
                        Set: <strong id="woSetNameLabel"></strong> &middot; Rarity: <strong id="woRarityLabel"></strong>
                    </p>

                    <label class="form-label">Quantity</label>
                    <input type="hidden" name="quantity" id="woQuantity" value="1" />
                    <div class="btn-group btn-group-sm w-100" role="group" aria-label="Quantity">
                        @for (var q = 1; q <= 3; q++)
                        {
                            <button type="button" class="btn @(q == 1 ? "btn-primary" : "btn-outline-secondary")"
                                    data-qty-target="woQuantity" data-qty-value="@q"
                                    onclick="selectQuantity(this)">@q</button>
                        }
                    </div>
                    <p class="text-muted small mt-2 mb-0">Condition, edition, and price are recorded later in the Cart, once you know what you actually bought.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add to Cart</button>
                </div>
            </form>
        </div>
    </div>
</div>
