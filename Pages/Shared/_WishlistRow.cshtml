@model CardCollector.ViewModels.WishlistRowViewModel
@using CardCollector.ViewModels
@{
    var item = Model.Item;
}
<div class="list-group-item" id="wishlist-row-@item.ImageID">
    <div class="d-flex flex-column flex-md-row gap-2 align-items-md-center py-1">
        <div class="d-flex gap-2 align-items-center flex-grow-1 min-width-0">
            <partial name="_CardThumbnail" model='new CardThumbnailViewModel(item.ImageURLSmall, item.CardName)' />
            <div class="min-width-0">
                <div class="fw-semibold">@item.CardName</div>
                <div class="text-muted small">@item.SetName &middot; <code>@item.SetCode</code> &middot; @item.RarityName</div>
            </div>
        </div>
        <div class="flex-shrink-0">
            @if (item.QuantityOwned > 0)
            {
                <span class="badge-status badge-status--warning">Need @item.QuantityNeeded <small class="opacity-75">(own @item.QuantityOwned)</small></span>
            }
            else
            {
                <span class="badge-neutral">Need @item.QuantityNeeded</span>
            }
        </div>
        <div class="d-flex gap-1 flex-shrink-0 cart-order-badges">
            @if (item.IsInCart)
            {
                <span class="badge bg-info text-dark badge-in-cart" title="Already staged in your cart">In Cart (@item.CartQuantity)</span>
            }
            @if (item.IsOrdered)
            {
                <span class="badge bg-success" title="Already has an active order">Ordered (@item.OrderedQuantity)</span>
            }
        </div>
        <div class="d-flex gap-1 flex-shrink-0">
            @if (item.QuantityNeeded > 0)
            {
                <button type="button"
                        class="btn btn-sm btn-primary"
                        data-filter-params="@Model.FilterParams"
                        data-set-code="@item.SetCode"
                        data-set-name="@item.SetName"
                        data-card-id="@item.CardID"
                        data-image-id="@item.ImageID"
                        data-rarity-name="@item.RarityName"
                        data-card-name="@item.CardName"
                        data-quantity-needed="@item.QuantityNeeded"
                        onclick="openWishlistOrderModal(this)">
                    Order
                </button>
            }
            <button type="button"
                    class="btn btn-sm btn-success"
                    data-filter-params="@Model.FilterParams"
                    data-set-code="@item.SetCode"
                    data-set-name="@item.SetName"
                    data-card-id="@item.CardID"
                    data-image-id="@item.ImageID"
                    data-rarity-name="@item.RarityName"
                    data-rarities="@string.Join(",", item.AvailableRarities)"
                    data-tcg-date="@Model.TCGDate"
                    onclick="openWishlistOwnModal(this)">
                Add to Collection
            </button>
            <form method="post" action="/Wishlist?handler=Remove&@Model.FilterParams" class="ajax-form"
                  data-ajax-target="wishlist-row-@item.ImageID"
                  onsubmit="return confirm('Remove this card from your wishlist?')">
                <input type="hidden" name="imageID" value="@item.ImageID" />
                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
            </form>
        </div>
    </div>
</div>
