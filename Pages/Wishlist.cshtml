@page
@model WishlistModel
@using CardCollector.Data.Models
@using CardCollector.ViewModels
@{
    ViewData["Title"] = "Wishlist";

    string SortIcon(WishlistSortBy col)
    {
        if (Model.SortBy != col) return "↕";
        return Model.SortDescending ? "↓" : "↑";
    }

    string SortURL(WishlistSortBy col)
    {
        bool desc = Model.SortBy == col && !Model.SortDescending;
        var q = string.IsNullOrWhiteSpace(Model.Query) ? "" : $"&query={Uri.EscapeDataString(Model.Query)}";
        var ct = string.IsNullOrWhiteSpace(Model.CardType) ? "" : $"&cardType={Uri.EscapeDataString(Model.CardType)}";
        var sn = string.IsNullOrWhiteSpace(Model.SetName) ? "" : $"&setName={Uri.EscapeDataString(Model.SetName)}";
        var rn = string.IsNullOrWhiteSpace(Model.RarityName) ? "" : $"&rarityName={Uri.EscapeDataString(Model.RarityName)}";
        return $"/Wishlist?sortBy={col}&sortDescending={desc}&pageSize={Model.PageSize}&pageNumber=1{q}{ct}{sn}{rn}";
    }

}

<div class="d-flex justify-content-between align-items-center mb-1">
    <h1>Wishlist</h1>
    <div class="d-flex align-items-center gap-2">
        <span class="badge bg-primary fs-6">@Model.Results.TotalCount needed</span>
        <a href="/Export?handler=Wishlist" class="btn btn-outline-secondary btn-sm">Export CSV</a>
    </div>
</div>


<p class="text-muted mb-4">Cards you still need: preferred versions you haven&rsquo;t ordered or owned yet, plus cards you own but haven&rsquo;t completed (@CardPrinting.CompleteThreshold copies). Use <a href="/Discover">Discover</a> to add more.</p>

<partial name="_SearchBar" model='new SearchBarViewModel(
    AutocompleteURL: "?handler=Autocomplete",
    FilterCount: Model.ActiveFilterCount,
    PageSize: Model.PageSize,
    Placeholder: "Search by name, set, or rarity…",
    Query: Model.Query)' />

<div class="collapse @(Model.HasActiveFilters ? "show" : "")" id="filterPanel">
    <div class="card card-body mb-3">
        <form method="get">
            <input type="hidden" name="pageNumber" value="1" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />
            <input type="hidden" name="sortBy" value="@Model.SortBy" />
            <input type="hidden" name="sortDescending" value="@Model.SortDescending" />
            @if (!string.IsNullOrWhiteSpace(Model.Query))
            {
                <input type="hidden" name="query" value="@Model.Query" />
            }
            <partial name="_AdvancedFilters" model='new AdvancedFiltersViewModel
            {
                AvailableRarityNames = Model.AvailableRarityNames,
                AvailableSetNames = Model.AvailableSetNames,
                CurrentCardType = Model.CardType,
                CurrentRarityName = Model.RarityName,
                CurrentSetName = Model.SetName
            }' />
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary btn-sm">Apply Filters</button>
                <a href="/Wishlist?sortBy=@Model.SortBy&sortDescending=@Model.SortDescending&pageSize=@Model.PageSize@(!string.IsNullOrWhiteSpace(Model.Query) ? $"&query={Uri.EscapeDataString(Model.Query)}" : "")"
                   class="btn btn-outline-secondary btn-sm">Clear Filters</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Results.Items.Any())
{
    <div class="alert alert-info text-center py-5">
        @if (string.IsNullOrEmpty(Model.Query) && !Model.HasActiveFilters)
        {
            <h4>Wishlist is empty</h4>
            <p class="mb-3">Head to <a href="/Discover">Discover</a> to pick your preferred version for each card.</p>
        }
        else
        {
            <span>No wishlist items match your search or filters.</span>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width: 60px;"></th>
                    <th>
                        <a href="@SortURL(WishlistSortBy.Name)"
                           class="text-white text-decoration-none @(Model.SortBy == WishlistSortBy.Name ? "fw-bold" : "fw-normal")">
                            Card @SortIcon(WishlistSortBy.Name)
                        </a>
                    </th>
                    <th>Set</th>
                    <th>Rarity</th>
                    <th>Need</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Results.Items)
                {
                    <tr>
                        <td>
                            <partial name="_CardThumbnail" model='new CardThumbnailViewModel(item.ImageURLSmall, item.CardName)' />
                        </td>
                        <td class="fw-semibold">@item.CardName</td>
                        <td>
                            <span class="d-block">@item.SetName</span>
                            <code class="text-muted small">@item.SetCode</code>
                        </td>
                        <td>@item.RarityName</td>
                        <td>
                            @if (item.QuantityOwned > 0)
                            {
                                <span class="badge bg-warning text-dark">Need @item.QuantityNeeded <small class="opacity-75">(own @item.QuantityOwned)</small></span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Need @item.QuantityNeeded</span>
                            }
                        </td>
                        <td class="text-nowrap">
                            <button type="button"
                                    class="btn btn-sm btn-primary me-1"
                                    data-set-code="@item.SetCode"
                                    data-set-name="@item.SetName"
                                    data-card-id="@item.CardID"
                                    data-image-id="@item.ImageID"
                                    data-rarity-name="@item.RarityName"
                                    data-rarities="@string.Join(",", item.AvailableRarities)"
                                    data-tcg-date="@Model.GetTCGDate(item.SetCode)"
                                    onclick="openWishlistModal(this, 'Order')">
                                Order
                            </button>
                            <button type="button"
                                    class="btn btn-sm btn-success me-1"
                                    data-set-code="@item.SetCode"
                                    data-set-name="@item.SetName"
                                    data-card-id="@item.CardID"
                                    data-image-id="@item.ImageID"
                                    data-rarity-name="@item.RarityName"
                                    data-rarities="@string.Join(",", item.AvailableRarities)"
                                    data-tcg-date="@Model.GetTCGDate(item.SetCode)"
                                    onclick="openWishlistModal(this, 'Own')">
                                Mark as Owned
                            </button>
                            <form method="post" asp-page-handler="Remove" class="d-inline"
                                  onsubmit="return confirm('Remove this card from your wishlist?')">
                                <input type="hidden" name="imageID" value="@item.ImageID" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model='new PaginationViewModel { AriaLabel = "Wishlist pagination", PageName = "Wishlist", PageNumber = Model.PageNumber, PageSize = Model.PageSize, Query = Model.Query, TotalPages = Model.Results.TotalPages, HasPreviousPage = Model.Results.HasPreviousPage, HasNextPage = Model.Results.HasNextPage, AdditionalParams = Model.GetPaginationParams() }' />
}

<!-- Order / Own Modal -->
<div class="modal fade" id="wishlistModal" tabindex="-1" aria-labelledby="wishlistModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="wishlistForm" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="wishlistModalLabel"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CardID" id="wlCardID" />
                    <input type="hidden" name="ImageID" id="wlImageID" />
                    <input type="hidden" name="SetCode" id="wlSetCode" />

                    <p class="text-muted mb-3">
                        Set: <strong id="wlSetName"></strong>
                    </p>

                    <partial name="_CollectionFormFields" model='new CollectionFormFieldsViewModel { Prefix = "wl" }' />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="wlSubmitBtn" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/wishlist.js"></script>
}
