@page
@model WishlistModel
@using CardCollector.Data.Models
@using CardCollector.ViewModels
@{
    ViewData["Title"] = "Wishlist";

    string SortIcon(WishlistSortBy col)
    {
        if (Model.SortBy != col) return "↕";
        return Model.SortDescending ? "↓" : "↑";
    }

    string SortURL(WishlistSortBy col)
    {
        bool desc = Model.SortBy == col && !Model.SortDescending;
        var q = string.IsNullOrWhiteSpace(Model.Query) ? "" : $"&query={Uri.EscapeDataString(Model.Query)}";
        var ct = string.IsNullOrWhiteSpace(Model.CardType) ? "" : $"&cardType={Uri.EscapeDataString(Model.CardType)}";
        var sn = string.IsNullOrWhiteSpace(Model.SetName) ? "" : $"&setName={Uri.EscapeDataString(Model.SetName)}";
        var rn = string.IsNullOrWhiteSpace(Model.RarityName) ? "" : $"&rarityName={Uri.EscapeDataString(Model.RarityName)}";
        return $"/Wishlist?sortBy={col}&sortDescending={desc}&pageSize={Model.PageSize}&pageNumber=1{q}{ct}{sn}{rn}";
    }

    var clearFiltersURL = $"/Wishlist?sortBy={Model.SortBy}&sortDescending={Model.SortDescending}&pageSize={Model.PageSize}{(!string.IsNullOrWhiteSpace(Model.Query) ? $"&query={Uri.EscapeDataString(Model.Query)}" : "")}";
    var filterParams = Model.GetFilterParams();

}

<div class="d-flex justify-content-between align-items-center mb-1">
    <h1>Wishlist</h1>
    <div class="d-flex align-items-center gap-2">
        <span class="badge-neutral fs-6" id="totalCountBadge" data-suffix="needed">@Model.Results.TotalCount needed</span>
        <a href="/Export?handler=Wishlist" class="btn btn-outline-secondary btn-sm">Export CSV</a>
    </div>
</div>


<p class="text-muted mb-4">Cards you still need: preferred versions you haven&rsquo;t ordered or owned yet, plus cards you own but haven&rsquo;t completed (@CardPrinting.CompleteThreshold copies). Use <a href="/Discover">Discover</a> to add more.</p>

<partial name="_SearchForm" model='new SearchFormViewModel
{
    ActiveFilterCount = Model.ActiveFilterCount,
    AutocompleteURL = "?handler=Autocomplete",
    ClearFiltersURL = clearFiltersURL,
    ExtraHiddenInputs = new Dictionary<string, string>
    {
        ["sortBy"] = Model.SortBy.ToString(),
        ["sortDescending"] = Model.SortDescending.ToString()
    },
    Filters = new AdvancedFiltersViewModel
    {
        AvailableRarityNames = Model.AvailableRarityNames,
        AvailableSetNames = Model.AvailableSetNames,
        CurrentCardType = Model.CardType,
        CurrentRarityName = Model.RarityName,
        CurrentSetName = Model.SetName
    },
    HasActiveFilters = Model.HasActiveFilters,
    PageSize = Model.PageSize,
    Placeholder = "Search by name, set, or rarity…",
    Query = Model.Query
}' />

@if (!Model.Results.Items.Any())
{
    <div class="alert alert-info text-center py-5">
        @if (string.IsNullOrEmpty(Model.Query) && !Model.HasActiveFilters)
        {
            <h4>Wishlist is empty</h4>
            <p class="mb-3">Head to <a href="/Discover">Discover</a> to pick your preferred version for each card.</p>
        }
        else
        {
            <span>No wishlist items match your search or filters.</span>
        }
    </div>
}
else
{
    <div class="table-responsive cc-table-card">
        <table class="table table-hover align-middle">
            <thead class="cc-table-head">
                <tr>
                    <th style="width: 60px;"></th>
                    <th>
                        <a href="@SortURL(WishlistSortBy.Name)"
                           class="text-body text-decoration-none @(Model.SortBy == WishlistSortBy.Name ? "fw-bold" : "fw-normal")">
                            Card @SortIcon(WishlistSortBy.Name)
                        </a>
                    </th>
                    <th class="d-none d-md-table-cell">Set</th>
                    <th class="d-none d-md-table-cell">Rarity</th>
                    <th>Need</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Results.Items)
                {
                    <partial name="_WishlistRow" model='new WishlistRowViewModel { FilterParams = filterParams, Item = item, TCGDate = Model.GetTCGDate(item.SetCode) }' />
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model='new PaginationViewModel { AriaLabel = "Wishlist pagination", PageName = "Wishlist", PageNumber = Model.PageNumber, PageSize = Model.PageSize, Query = Model.Query, TotalPages = Model.Results.TotalPages, HasPreviousPage = Model.Results.HasPreviousPage, HasNextPage = Model.Results.HasNextPage, AdditionalParams = Model.GetPaginationParams() }' />
}

<!-- Order / Own Modal -->
<div class="modal fade" id="wishlistModal" tabindex="-1" aria-labelledby="wishlistModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-fullscreen-sm-down">
        <div class="modal-content">
            <form id="wishlistForm" method="post" class="ajax-form">
                <div class="modal-header">
                    <h5 class="modal-title" id="wishlistModalLabel"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CardID" id="wlCardID" />
                    <input type="hidden" name="ImageID" id="wlImageID" />
                    <input type="hidden" name="SetCode" id="wlSetCode" />

                    <p class="text-muted mb-3">
                        Set: <strong id="wlSetName"></strong>
                    </p>

                    <partial name="_CollectionFormFields" model='new CollectionFormFieldsViewModel { Prefix = "wl" }' />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="wlSubmitBtn" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/collection-groups.js" asp-append-version="true"></script>
    <script src="~/js/wishlist.js" asp-append-version="true"></script>
}
