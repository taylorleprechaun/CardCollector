@page
@model WishlistModel
@using CardCollector.Data.Models
@using CardCollector.ViewModels
@{
    ViewData["Title"] = "Wishlist";

    string SortIcon(WishlistSortBy col)
    {
        if (Model.SortBy != col) return "↕";
        return Model.SortDescending ? "↓" : "↑";
    }

    string SortURL(WishlistSortBy col)
    {
        bool desc = Model.SortBy == col && !Model.SortDescending;
        var q = string.IsNullOrWhiteSpace(Model.Query) ? "" : $"&query={Uri.EscapeDataString(Model.Query)}";
        return $"/Wishlist?sortBy={col}&sortDescending={desc}&pageSize={Model.PageSize}&pageNumber=1{q}";
    }
}

<div class="d-flex justify-content-between align-items-center mb-1">
    <h1>Wishlist</h1>
    <div class="d-flex align-items-center gap-2">
        <span class="badge bg-primary fs-6">@Model.Results.TotalCount to acquire</span>
        <a href="/Export?handler=Wishlist" class="btn btn-outline-secondary btn-sm">Export CSV</a>
    </div>
</div>


<p class="text-muted mb-4">Preferred versions you haven&rsquo;t ordered or owned yet. Use <a href="/Discover">Discover</a> to add more.</p>

<partial name="_SearchBar" model='new SearchBarViewModel("Search by name, set, or rarity…", "?handler=Autocomplete", Model.PageSize, Model.Query)' />

@if (!Model.Results.Items.Any())
{
    <div class="alert alert-info text-center py-5">
        @if (string.IsNullOrEmpty(Model.Query))
        {
            <h4>Wishlist is empty</h4>
            <p class="mb-3">Head to <a href="/Discover">Discover</a> to pick your preferred version for each card.</p>
        }
        else
        {
            <span>No wishlist items match &ldquo;@Model.Query&rdquo;.</span>
        }
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width: 60px;"></th>
                    <th>
                        <a href="@SortURL(WishlistSortBy.Name)"
                           class="text-white text-decoration-none @(Model.SortBy == WishlistSortBy.Name ? "fw-bold" : "fw-normal")">
                            Card @SortIcon(WishlistSortBy.Name)
                        </a>
                    </th>
                    <th>Set</th>
                    <th>Rarity</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Results.Items)
                {
                    <tr>
                        <td>
                            <partial name="_CardThumbnail" model='new CardThumbnailViewModel(item.ImageURLSmall, item.CardName)' />
                        </td>
                        <td class="fw-semibold">@item.CardName</td>
                        <td>
                            <span class="d-block">@item.SetName</span>
                            <code class="text-muted small">@item.SetCode</code>
                        </td>
                        <td>@item.RarityName</td>
                        <td class="text-nowrap">
                            <button type="button"
                                    class="btn btn-sm btn-primary me-1"
                                    data-set-code="@item.SetCode"
                                    data-set-name="@item.SetName"
                                    data-card-id="@item.CardID"
                                    data-image-id="@item.ImageID"
                                    data-rarity-name="@item.RarityName"
                                    data-rarities="@string.Join(",", item.AvailableRarities)"
                                    data-tcg-date="@Model.GetTCGDate(item.SetCode)"
                                    onclick="openWishlistModal(this, 'Order')">
                                Order
                            </button>
                            <button type="button"
                                    class="btn btn-sm btn-success me-1"
                                    data-set-code="@item.SetCode"
                                    data-set-name="@item.SetName"
                                    data-card-id="@item.CardID"
                                    data-image-id="@item.ImageID"
                                    data-rarity-name="@item.RarityName"
                                    data-rarities="@string.Join(",", item.AvailableRarities)"
                                    data-tcg-date="@Model.GetTCGDate(item.SetCode)"
                                    onclick="openWishlistModal(this, 'Own')">
                                Mark as Owned
                            </button>
                            <form method="post" asp-page-handler="Remove" class="d-inline"
                                  onsubmit="return confirm('Remove this card from your wishlist?')">
                                <input type="hidden" name="imageID" value="@item.ImageID" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <partial name="_Pagination" model='new PaginationViewModel { AriaLabel = "Wishlist pagination", PageName = "Wishlist", PageNumber = Model.PageNumber, PageSize = Model.PageSize, Query = Model.Query, TotalPages = Model.Results.TotalPages, HasPreviousPage = Model.Results.HasPreviousPage, HasNextPage = Model.Results.HasNextPage, AdditionalParams = Model.GetPaginationParams() }' />
}

<!-- Order / Own Modal -->
<div class="modal fade" id="wishlistModal" tabindex="-1" aria-labelledby="wishlistModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="wishlistForm" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="wishlistModalLabel"></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="CardID" id="wlCardID" />
                    <input type="hidden" name="ImageID" id="wlImageID" />
                    <input type="hidden" name="SetCode" id="wlSetCode" />

                    <p class="text-muted mb-3">
                        Set: <strong id="wlSetName"></strong>
                    </p>

                    <partial name="_CollectionFormFields" model='new CollectionFormFieldsViewModel { Prefix = "wl" }' />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" id="wlSubmitBtn" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/wishlist.js"></script>
}
