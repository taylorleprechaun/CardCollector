@page
@model CardCollector.Pages.StatsModel
@{
    ViewData["Title"] = "Collection Stats";
}

<h2 class="mb-4">Collection Stats</h2>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Top 20 Sets by Count</div>
            <div class="card-body">
                @if (Model.Stats.SetBreakdown.Count == 0)
                {
                    <p class="text-muted">No owned cards yet.</p>
                }
                else
                {
                    <div style="height:560px; position:relative">
                        <canvas id="setChart"></canvas>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Top 20 Sets by Market Value</div>
            <div class="card-body">
                @if (Model.Stats.SetValueBreakdown.Count == 0)
                {
                    <p class="text-muted" id="noSetValueMsg">No market value data yet. Click &ldquo;Calculate Current Market Value&rdquo; below to populate this chart.</p>
                }
                <div id="setValueChartWrapper" style="height:560px; position:relative; @(Model.Stats.SetValueBreakdown.Count == 0 ? "display:none" : "")">
                    <canvas id="setValueChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Rarity Breakdown</div>
            <div class="card-body">
                @if (Model.Stats.RarityBreakdown.Count == 0)
                {
                    <p class="text-muted">No owned cards yet.</p>
                }
                else
                {
                    <ol class="list-group list-group-flush list-group-numbered">
                        @for (int i = 0; i < Model.Stats.RarityBreakdown.Count; i++)
                        {
                            var item = Model.Stats.RarityBreakdown[i];
                            var badgeStyle = i == 0 ? "background-color:#FFD700;color:#000" : i == 1 ? "background-color:#C0C0C0;color:#000" : i == 2 ? "background-color:#CD7F32;color:#fff" : "background-color:#6c757d;color:#fff";
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @item.Label
                                <span class="badge rounded-pill" style="@badgeStyle">@item.Count</span>
                            </li>
                        }
                    </ol>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Acquisition Method</div>
            <div class="card-body">
                @if (Model.Stats.AcquisitionBreakdown.Count == 0)
                {
                    <p class="text-muted">No owned cards yet.</p>
                }
                else
                {
                    <ol class="list-group list-group-flush list-group-numbered">
                        @for (int i = 0; i < Model.Stats.AcquisitionBreakdown.Count; i++)
                        {
                            var item = Model.Stats.AcquisitionBreakdown[i];
                            var badgeStyle = i == 0 ? "background-color:#FFD700;color:#000" : i == 1 ? "background-color:#C0C0C0;color:#000" : i == 2 ? "background-color:#CD7F32;color:#fff" : "background-color:#6c757d;color:#fff";
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @item.Label
                                <span class="badge rounded-pill" style="@badgeStyle">@item.Count</span>
                            </li>
                        }
                    </ol>
                }
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold">Top 10 Most Valuable Cards</div>
    <div class="card-body">
        @if (Model.Stats.TopValueCards.Count == 0)
        {
            <p class="text-muted" id="noTopCardsMsg">No market value data yet. Click &ldquo;Calculate Current Market Value&rdquo; below to populate this section.</p>
        }
        <div id="topCardsWrapper" @(Model.Stats.TopValueCards.Count == 0 ? "style=\"display:none\"" : "")>
            <table class="table table-sm table-striped mb-0">
                <thead>
                    <tr>
                        <th class="text-center">#</th>
                        <th>Card</th>
                        <th>Set</th>
                        <th>Rarity</th>
                        <th class="text-end">Market Value</th>
                    </tr>
                </thead>
                <tbody id="topCardsBody">
                    @for (int i = 0; i < Model.Stats.TopValueCards.Count; i++)
                    {
                        var card = Model.Stats.TopValueCards[i];
                        <tr>
                            @if (i < 3)
                            {
                                var rankStyle = i == 0 ? "background-color:#FFD700;color:#000" : i == 1 ? "background-color:#C0C0C0;color:#000" : "background-color:#CD7F32;color:#fff";
                                <td class="text-center"><span class="badge rounded-pill" style="@rankStyle">@(i + 1)</span></td>
                            }
                            else
                            {
                                <td class="text-center text-muted">@(i + 1)</td>
                            }
                            <td>@card.CardName</td>
                            <td>@card.SetName</td>
                            <td>@card.RarityName</td>
                            <td class="text-end">$@card.Value.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
        <span>Collection Value Over Time</span>
        <button id="calcValueBtn" class="btn btn-sm btn-primary" onclick="calculateValue()">
            Calculate Current Market Value
        </button>
    </div>
    <div class="card-body">
        <div id="calcStatus" class="mb-3" style="display:none">
            <div id="calcSpinner" style="display:none; align-items:center; gap:0.5rem">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <span>Fetching prices&hellip; this may take a minute for large collections.</span>
            </div>
            <div id="calcResult" class="alert alert-success mb-0" style="display:none"></div>
            <div id="calcError" class="alert alert-danger mb-0" style="display:none"></div>
        </div>
        @if (Model.Stats.ValueHistory.Count == 0)
        {
            <p class="text-muted" id="noHistoryMsg">No value snapshots yet. Click the button above to calculate your collection&rsquo;s current market value.</p>
        }
        <canvas id="valueChart" @(Model.Stats.ValueHistory.Count == 0 ? "style=\"display:none\"" : "")></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <script>
        const setLabels = @Html.Raw(Model.Stats.SetLabelsJson);
        const setCounts = @Html.Raw(Model.Stats.SetCountsJson);
        const setValueLabels = @Html.Raw(Model.Stats.SetValueLabelsJson);
        const setValueData = @Html.Raw(Model.Stats.SetValueDataJson);
        const historyDates = @Html.Raw(Model.Stats.ValueHistoryDatesJson);
        const historyValues = @Html.Raw(Model.Stats.ValueHistoryValuesJson);
        const historyCardCounts = @Html.Raw(Model.Stats.ValueHistoryCardCountsJson);
    </script>
    <script src="~/js/stats.js"></script>
}
