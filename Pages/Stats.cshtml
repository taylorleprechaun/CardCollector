@page
@model CardCollector.Pages.StatsModel
@{
    ViewData["Title"] = "Collection Stats";
}

<h2 class="mb-4">Collection Stats</h2>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Top 20 Sets by Count</div>
            <div class="card-body">
                @if (Model.Stats.SetBreakdown.Count == 0)
                {
                    <p class="text-muted">No owned cards yet.</p>
                }
                else
                {
                    <div style="height:560px; position:relative">
                        <canvas id="setChart"></canvas>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Top 20 Sets by Market Value</div>
            <div class="card-body">
                @if (Model.Stats.SetValueBreakdown.Count == 0)
                {
                    <p class="text-muted" id="noSetValueMsg">No market value data yet. Market value is refreshed automatically each night.</p>
                }
                <div id="setValueChartWrapper" style="height:560px; position:relative; @(Model.Stats.SetValueBreakdown.Count == 0 ? "display:none" : "")">
                    <canvas id="setValueChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Rarity Breakdown</div>
            <div class="card-body">
                @if (Model.Stats.RarityBreakdown.Count == 0)
                {
                    <p class="text-muted">No owned cards yet.</p>
                }
                else
                {
                    <ol class="list-group list-group-flush list-group-numbered">
                        @for (int i = 0; i < Model.Stats.RarityBreakdown.Count; i++)
                        {
                            var item = Model.Stats.RarityBreakdown[i];
                            var badgeClass = i == 0 ? "medal-badge-gold" : i == 1 ? "medal-badge-silver" : i == 2 ? "medal-badge-bronze" : "bg-secondary text-white";
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @item.Label
                                <span class="badge rounded-pill @badgeClass">@item.Count</span>
                            </li>
                        }
                    </ol>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Acquisition Method</div>
            <div class="card-body">
                @if (Model.Stats.AcquisitionBreakdown.Count == 0)
                {
                    <p class="text-muted">No owned cards yet.</p>
                }
                else
                {
                    <ol class="list-group list-group-flush list-group-numbered">
                        @for (int i = 0; i < Model.Stats.AcquisitionBreakdown.Count; i++)
                        {
                            var item = Model.Stats.AcquisitionBreakdown[i];
                            var badgeClass = i == 0 ? "medal-badge-gold" : i == 1 ? "medal-badge-silver" : i == 2 ? "medal-badge-bronze" : "bg-secondary text-white";
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @item.Label
                                <span class="badge rounded-pill @badgeClass">@item.Count</span>
                            </li>
                        }
                    </ol>
                }
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold">Top 10 Most Valuable Cards</div>
    <div class="card-body">
        @if (Model.Stats.TopValueCards.Count == 0)
        {
            <p class="text-muted" id="noTopCardsMsg">No market value data yet. Market value is refreshed automatically each night.</p>
        }
        <div id="topCardsWrapper" @(Model.Stats.TopValueCards.Count == 0 ? "style=\"display:none\"" : "")>
            <div class="table-responsive cc-table-card">
            <table class="table table-sm table-striped mb-0">
                <thead class="cc-table-head">
                    <tr>
                        <th class="text-center">#</th>
                        <th>Card</th>
                        <th>Set</th>
                        <th>Rarity</th>
                        <th class="text-end">Market Value</th>
                    </tr>
                </thead>
                <tbody id="topCardsBody">
                    @for (int i = 0; i < Model.Stats.TopValueCards.Count; i++)
                    {
                        var card = Model.Stats.TopValueCards[i];
                        <tr>
                            @if (i < 3)
                            {
                                var rankClass = i == 0 ? "medal-badge-gold" : i == 1 ? "medal-badge-silver" : "medal-badge-bronze";
                                <td class="text-center"><span class="badge rounded-pill @rankClass">@(i + 1)</span></td>
                            }
                            else
                            {
                                <td class="text-center text-muted">@(i + 1)</td>
                            }
                            <td>@card.CardName</td>
                            <td>@card.SetName</td>
                            <td>@card.RarityName</td>
                            <td class="text-end">$@card.Value.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold">Collection Value Over Time</div>
    <div class="card-body">
        @if (Model.Stats.ValueHistory.Count == 0)
        {
            <p class="text-muted" id="noHistoryMsg">No value snapshots yet. Market value is refreshed automatically each night.</p>
        }
        <canvas id="valueChart" @(Model.Stats.ValueHistory.Count == 0 ? "style=\"display:none\"" : "")></canvas>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold">Card Price History</div>
    <div class="card-body">
        <div class="d-flex gap-2 mb-3 align-items-center">
            <div class="position-relative flex-grow-1" style="max-width:600px">
                <input id="cardHistoryInput" class="form-control"
                       placeholder="Type a card name&hellip;" autocomplete="off" />
                <div id="cardHistoryDropdown" class="cc-typeahead-menu"></div>
            </div>
            <button class="btn btn-primary" onclick="loadCardPriceHistory()">Load History</button>
        </div>
        <div id="cardHistoryStatus" class="text-muted small mb-2" style="display:none"></div>
        <div class="row g-3">
            <div class="col-md-9">
                <div id="cardHistoryChartWrapper" style="display:none; position:relative; height:300px">
                    <canvas id="cardHistoryChart"></canvas>
                </div>
            </div>
            <div class="col-md-3 text-center align-self-center"
                 id="cardHistoryImageWrapper" style="display:none">
                <img id="cardHistoryImg" src="" alt=""
                     style="max-width:100%; max-height:300px; object-fit:contain" />
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
        <span>Card Data</span>
        <button id="refreshCardDataBtn" class="btn btn-sm btn-outline-secondary">
            Redownload Card Data
        </button>
    </div>
    <div class="card-body">
        <p class="text-muted small mb-2">Downloads the latest card list from yaml-yugi and images from YGOProDeck, updates the local cache and in-memory data immediately.</p>
        <div id="cardDataStatus" style="display:none">
            <small id="cardDataProgress" class="text-muted">Downloading&hellip;</small>
            <div id="cardDataResult" class="alert alert-success mb-0 mt-2" style="display:none"></div>
            <div id="cardDataError" class="alert alert-danger mb-0 mt-2" style="display:none"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <script>
        const setLabels = @Html.Raw(Model.Stats.SetLabelsJson);
        const setCounts = @Html.Raw(Model.Stats.SetCountsJson);
        const setValueLabels = @Html.Raw(Model.Stats.SetValueLabelsJson);
        const setValueData = @Html.Raw(Model.Stats.SetValueDataJson);
        const historyDates = @Html.Raw(Model.Stats.ValueHistoryDatesJson);
        const historyValues = @Html.Raw(Model.Stats.ValueHistoryValuesJson);
        const historyCardCounts = @Html.Raw(Model.Stats.ValueHistoryCardCountsJson);
        const trackedCardImageMap = @Html.Raw(Model.TrackedCardImageMapJson);
    </script>
    <script src="~/js/stats.js" asp-append-version="true"></script>
}
