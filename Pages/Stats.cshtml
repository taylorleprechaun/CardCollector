@page
@model CardCollector.Pages.StatsModel
@{
    ViewData["Title"] = "Collection Stats";
}

<h2 class="mb-4">Collection Stats</h2>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Top 20 Sets by Count</div>
            <div class="card-body">
                @if (Model.Stats.SetBreakdown.Count == 0)
                {
                    <p class="text-muted">No owned cards yet.</p>
                }
                else
                {
                    <canvas id="setChart"></canvas>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Top 20 Sets by Market Value</div>
            <div class="card-body">
                @if (Model.Stats.SetValueBreakdown.Count == 0)
                {
                    <p class="text-muted" id="noSetValueMsg">No market value data yet. Click &ldquo;Calculate Current Market Value&rdquo; below to populate this chart.</p>
                }
                <canvas id="setValueChart" @(Model.Stats.SetValueBreakdown.Count == 0 ? "style=\"display:none\"" : "")></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Rarity Breakdown</div>
            <div class="card-body d-flex align-items-center justify-content-center">
                @if (Model.Stats.RarityBreakdown.Count == 0)
                {
                    <p class="text-muted">No owned cards yet.</p>
                }
                else
                {
                    <div style="max-width:400px; width:100%">
                        <canvas id="rarityChart"></canvas>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Acquisition Method</div>
            <div class="card-body d-flex align-items-center justify-content-center">
                @if (Model.Stats.AcquisitionBreakdown.Count == 0)
                {
                    <p class="text-muted">No owned cards yet.</p>
                }
                else
                {
                    <div style="max-width:400px; width:100%">
                        <canvas id="acquisitionChart"></canvas>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
        <span>Collection Value Over Time</span>
        <button id="calcValueBtn" class="btn btn-sm btn-primary" onclick="calculateValue()">
            Calculate Current Market Value
        </button>
    </div>
    <div class="card-body">
        <div id="calcStatus" class="mb-3" style="display:none">
            <div id="calcSpinner" style="display:none; align-items:center; gap:0.5rem">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <span>Fetching prices&hellip; this may take a minute for large collections.</span>
            </div>
            <div id="calcResult" class="alert alert-success mb-0" style="display:none"></div>
            <div id="calcError" class="alert alert-danger mb-0" style="display:none"></div>
        </div>
        @if (Model.Stats.ValueHistory.Count == 0)
        {
            <p class="text-muted" id="noHistoryMsg">No value snapshots yet. Click the button above to calculate your collection&rsquo;s current market value.</p>
        }
        <canvas id="valueChart" @(Model.Stats.ValueHistory.Count == 0 ? "style=\"display:none\"" : "")></canvas>
    </div>
</div>

@section Scripts {
    <script>
        const rarityLabels = @Html.Raw(Model.Stats.RarityLabelsJson);
        const rarityCounts = @Html.Raw(Model.Stats.RarityCountsJson);
        const setLabels = @Html.Raw(Model.Stats.SetLabelsJson);
        const setCounts = @Html.Raw(Model.Stats.SetCountsJson);
        const acqLabels = @Html.Raw(Model.Stats.AcquisitionLabelsJson);
        const acqCounts = @Html.Raw(Model.Stats.AcquisitionCountsJson);
        const setValueLabels = @Html.Raw(Model.Stats.SetValueLabelsJson);
        const setValueData = @Html.Raw(Model.Stats.SetValueDataJson);
        const historyDates = @Html.Raw(Model.Stats.ValueHistoryDatesJson);
        const historyValues = @Html.Raw(Model.Stats.ValueHistoryValuesJson);
    </script>
    <script src="~/js/stats.js"></script>
}
