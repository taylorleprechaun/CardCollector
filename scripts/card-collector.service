[Unit]
Description=CardCollector Web App
After=network.target

[Service]
WorkingDirectory=/var/www/card-collector
ExecStart=/usr/bin/dotnet /var/www/card-collector/CardCollector.dll --urls "http://localhost:5100"
Restart=always
RestartSec=10
SyslogIdentifier=card-collector
User=www-data
Environment=ASPNETCORE_ENVIRONMENT=Production

[Install]
WantedBy=multi-user.target
